@page "/settings"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Tenant:Self")]
@inject IStringLocalizer<TenantText> L
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject UserManager<IdentityUser<Guid>> UserManager
@inject SignInManager<IdentityUser<Guid>> SignInManager
@inject TenantUserPreferenceService PreferenceService
@using TabFlow.Shared.Domain

<PageTitle>@L["SettingsTitle"]</PageTitle>

<SectionContent SectionName="tenant-header">
    <div>
        <p class="eyebrow">@L["AccountEyebrow"]</p>
        <h2>@L["SettingsTitle"]</h2>
        <p class="hero-copy">@L["SettingsHero"]</p>
    </div>
</SectionContent>

<SectionContent SectionName="tenant-inspector">
    <div class="console-context">
        <section class="context-card">
            <p class="eyebrow">@L["MetricAccount"]</p>
            <h4>@DisplayEmail</h4>
            <p class="detail-copy">@L["StoredForAccount"]</p>
        </section>
        <section class="context-card">
            <div class="kv-grid">
                <div class="kv-item">
                    <span class="kv-label">@L["Language"]</span>
                    <span class="kv-value">@PreferenceModel.Language</span>
                </div>
                <div class="kv-item">
                    <span class="kv-label">@L["Density"]</span>
                    <span class="kv-value">@PreferenceModel.Density</span>
                </div>
                <div class="kv-item form-span-2">
                    <span class="kv-label">@L["TimeZone"]</span>
                    <span class="kv-value">@PreferenceModel.TimeZone</span>
                </div>
            </div>
        </section>
    </div>
</SectionContent>

@if (LoadError is not null)
{
    <div class="alert alert-danger">@LoadError</div>
}
else
{
    <section class="stats-grid compact-stats">
        <article class="metric-card">
            <p class="metric-label">@L["MetricAccount"]</p>
            <p class="metric-value metric-value-sm">@DisplayEmail</p>
        </article>
        <article class="metric-card">
            <p class="metric-label">@L["MetricUiLanguage"]</p>
            <p class="metric-value metric-value-sm">@PreferenceModel.Language</p>
            <p class="metric-footnote">@L["StoredForAccount"]</p>
        </article>
        <article class="metric-card">
            <p class="metric-label">@L["TimeZone"]</p>
            <p class="metric-value metric-value-sm">@PreferenceModel.TimeZone</p>
            <p class="metric-footnote">@PreferencePreview</p>
        </article>
    </section>

    <section class="panel">
        <div class="tab-strip" role="tablist" aria-label="Settings sections">
            <button type="button" class="@TabClass("preferences")" @onclick='() => SelectTab("preferences")'>@L["Preferences"]</button>
            <button type="button" class="@TabClass("security")" @onclick='() => SelectTab("security")'>@L["Security"]</button>
        </div>
    </section>

    @if (ActiveTab == "preferences")
    {
        <section class="detail-layout">
            <article class="panel detail-panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">@L["Preferences"]</p>
                        <h3>@L["OperatorDefaults"]</h3>
                    </div>
                </div>

                @if (PreferenceSuccess is not null)
                {
                    <div class="alert alert-success">@PreferenceSuccess</div>
                }

                <EditForm Model="@PreferenceModel" OnValidSubmit="SavePreferencesAsync">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>@L["MetricUiLanguage"]</label>
                            <InputSelect @bind-Value="PreferenceModel.Language" class="form-control">
                                <option value="en-GB">@L["EnglishUk"]</option>
                                <option value="tr-TR">@L["Turkish"]</option>
                            </InputSelect>
                        </div>

                        <div class="form-group">
                            <label>@L["Density"]</label>
                            <InputSelect @bind-Value="PreferenceModel.Density" class="form-control">
                                <option value="compact">@L["Compact"]</option>
                                <option value="comfortable">@L["Comfortable"]</option>
                            </InputSelect>
                        </div>

                        <div class="form-group form-span-2">
                            <label>@L["OperatorTimeZone"]</label>
                            <InputSelect @bind-Value="PreferenceModel.TimeZone" class="form-control">
                                <option value="UTC">UTC</option>
                                <option value="Europe/London">Europe/London</option>
                                <option value="Europe/Istanbul">Europe/Istanbul</option>
                                <option value="America/New_York">America/New_York</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary" disabled="@IsSavingPreferences">
                            @(IsSavingPreferences ? L["Saving"] : L["SavePreferences"])
                        </button>
                    </div>
                </EditForm>
            </article>

            <article class="panel detail-panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">@L["Preview"]</p>
                        <h3>@L["SessionDefaults"]</h3>
                    </div>
                </div>

                <div class="detail-stack">
                    <div class="kv-grid">
                        <div class="kv-item">
                            <span class="kv-label">@L["Language"]</span>
                            <span class="kv-value">@PreferenceModel.Language</span>
                        </div>
                        <div class="kv-item">
                            <span class="kv-label">@L["Density"]</span>
                            <span class="kv-value">@PreferenceModel.Density</span>
                        </div>
                        <div class="kv-item form-span-2">
                            <span class="kv-label">@L["TimeZonePreview"]</span>
                            <span class="kv-value">@PreferencePreview</span>
                        </div>
                    </div>

                    <section class="detail-section">
                        <p class="detail-title">@L["Scope"]</p>
                        <p class="detail-copy">@L["SettingsScopeCopy"]</p>
                    </section>
                </div>
            </article>
        </section>
    }
    else
    {
        <section class="detail-layout">
            <article class="panel detail-panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">@L["Security"]</p>
                        <h3>@L["UpdatePassword"]</h3>
                    </div>
                </div>

                @if (SecuritySuccess is not null)
                {
                    <div class="alert alert-success">@SecuritySuccess</div>
                }

                @if (SecurityError is not null)
                {
                    <div class="alert alert-danger">@SecurityError</div>
                }

                <EditForm Model="@PasswordModel" OnValidSubmit="ChangePasswordAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="form-grid">
                        <div class="form-group form-span-2">
                            <label>@L["CurrentPassword"]</label>
                            <InputText @bind-Value="PasswordModel.CurrentPassword" type="password" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>@L["NewPassword"]</label>
                            <InputText @bind-Value="PasswordModel.NewPassword" type="password" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>@L["ConfirmPassword"]</label>
                            <InputText @bind-Value="PasswordModel.ConfirmPassword" type="password" class="form-control" />
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary" disabled="@IsSavingPassword">
                            @(IsSavingPassword ? L["Updating"] : L["UpdatePassword"])
                        </button>
                    </div>
                </EditForm>
            </article>

            <article class="panel detail-panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">@L["Security"]</p>
                        <h3>Two-Factor Authentication</h3>
                    </div>
                </div>
                <div class="detail-stack">
                    <section class="detail-section">
                        <p class="detail-title">Status</p>
                        <p class="detail-copy">@(IsTwoFactorEnabled ? "Authenticator app verified for this account." : "Finish authenticator setup before leaving this session.")</p>
                    </section>

                    @if (SecurityError is not null)
                    {
                        <div class="alert alert-danger">@SecurityError</div>
                    }

                    @if (MfaSuccess is not null)
                    {
                        <div class="alert alert-success">@MfaSuccess</div>
                    }

                    @if (!IsTwoFactorEnabled)
                    {
                        <EditForm Model="@MfaModel" OnValidSubmit="EnableTwoFactorAsync">
                            <div class="form-grid">
                                <div class="kv-item form-span-2">
                                    <span class="kv-label">Authenticator Key</span>
                                    <span class="kv-value">@FormattedAuthenticatorKey</span>
                                </div>
                                <div class="form-group form-span-2">
                                    <label>Verification Code</label>
                                    <InputText @bind-Value="MfaModel.VerificationCode" class="form-control" />
                                </div>
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="btn btn-primary" disabled="@IsSavingMfa">
                                    @(IsSavingMfa ? "Verifying" : "Enable Two-Factor")
                                </button>
                            </div>
                        </EditForm>
                    }

                    @if (RecoveryCodes.Count > 0)
                    {
                        <section class="detail-section">
                            <p class="detail-title">Recovery Codes</p>
                            <div class="step-list">
                                @foreach (var recoveryCode in RecoveryCodes)
                                {
                                    <div class="step-item">
                                        <p class="list-title">@recoveryCode</p>
                                    </div>
                                }
                            </div>
                        </section>
                    }
                </div>
            </article>
        </section>
    }
}

@code {
    [SupplyParameterFromQuery(Name = "tab")]
    public string? Tab { get; set; }

    [SupplyParameterFromQuery(Name = "saved")]
    public int? Saved { get; set; }

    private bool IsSavingPassword;
    private bool IsSavingPreferences;
    private bool IsSavingMfa;
    private string ActiveTab { get; set; } = "preferences";
    private string? DisplayEmail;
    private string? LoadError;
    private string? PreferenceSuccess;
    private string? SecurityError;
    private string? SecuritySuccess;
    private string? MfaSuccess;
    private string? FormattedAuthenticatorKey;
    private bool IsTwoFactorEnabled;
    private IdentityUser<Guid>? CurrentUser;
    private PasswordChangeInput PasswordModel { get; set; } = new();
    private MfaEnrollmentInput MfaModel { get; set; } = new();
    private UserPreferenceInput PreferenceModel { get; set; } = new();
    private List<string> RecoveryCodes { get; set; } = [];

    private string PreferencePreview =>
        $"{PreferenceModel.TimeZone} · {FormatPreviewTime()}";

    protected override async Task OnInitializedAsync()
    {
        ActiveTab = string.Equals(Tab, "security", StringComparison.OrdinalIgnoreCase) ? "security" : "preferences";
        PreferenceSuccess = Saved == 1 ? L["PreferencesSavedSuccess"].Value : null;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var principal = authState.User;
            CurrentUser = await UserManager.GetUserAsync(principal);
            DisplayEmail = CurrentUser?.Email ?? principal.Identity?.Name ?? "Operator";

            var preference = await PreferenceService.GetForPrincipalAsync(principal);
            PreferenceModel = new UserPreferenceInput
            {
                Language = preference.LanguageCode,
                TimeZone = preference.TimeZone,
                Density = preference.Density,
            };

            await LoadSecurityStateAsync();
        }
        catch (Exception ex)
        {
            LoadError = L["SettingsLoadError", ex.Message];
        }
    }

    private void SelectTab(string tab)
    {
        ActiveTab = tab;
        PreferenceSuccess = null;
        SecuritySuccess = null;
        SecurityError = null;
        MfaSuccess = null;
    }

    private async Task SavePreferencesAsync()
    {
        IsSavingPreferences = true;
        PreferenceSuccess = null;

        try
        {
            var languageChanged = !string.Equals(CultureInfo.CurrentUICulture.Name, PreferenceModel.Language, StringComparison.OrdinalIgnoreCase);
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            await PreferenceService.SaveForPrincipalAsync(authState.User, new TenantUserPreferenceModel(
                PreferenceModel.Language,
                PreferenceModel.TimeZone,
                PreferenceModel.Density));

            PreferenceSuccess = L["PreferencesSavedSuccess"];
            if (languageChanged)
            {
                NavigationManager.NavigateTo("/settings?tab=preferences&saved=1", forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            LoadError = L["PreferencesSaveFailed", ex.Message];
        }
        finally
        {
            IsSavingPreferences = false;
        }
    }

    private async Task ChangePasswordAsync()
    {
        IsSavingPassword = true;
        SecurityError = null;
        SecuritySuccess = null;

        try
        {
            var user = CurrentUser;
            if (user is null)
            {
                SecurityError = L["AccountMissingError"];
                return;
            }

            if (!string.Equals(PasswordModel.NewPassword, PasswordModel.ConfirmPassword, StringComparison.Ordinal))
            {
                SecurityError = L["PasswordMismatchError"];
                return;
            }

            var result = await UserManager.ChangePasswordAsync(user, PasswordModel.CurrentPassword, PasswordModel.NewPassword);
            if (!result.Succeeded)
            {
                SecurityError = string.Join(" ", result.Errors.Select(error => error.Description));
                return;
            }

            await SignInManager.RefreshSignInAsync(user);
            PasswordModel = new PasswordChangeInput();
            SecuritySuccess = L["PasswordUpdatedSuccess"];
        }
        catch (Exception ex)
        {
            SecurityError = L["PasswordChangeFailed", ex.Message];
        }
        finally
        {
            IsSavingPassword = false;
        }
    }

    private async Task LoadSecurityStateAsync()
    {
        if (CurrentUser is null)
        {
            return;
        }

        IsTwoFactorEnabled = await UserManager.GetTwoFactorEnabledAsync(CurrentUser);
        if (IsTwoFactorEnabled)
        {
            FormattedAuthenticatorKey = null;
            return;
        }

        var key = await UserManager.GetAuthenticatorKeyAsync(CurrentUser);
        if (string.IsNullOrWhiteSpace(key))
        {
            await UserManager.ResetAuthenticatorKeyAsync(CurrentUser);
            key = await UserManager.GetAuthenticatorKeyAsync(CurrentUser);
        }

        FormattedAuthenticatorKey = FormatAuthenticatorKey(key ?? string.Empty);
    }

    private async Task EnableTwoFactorAsync()
    {
        IsSavingMfa = true;
        SecurityError = null;
        MfaSuccess = null;

        try
        {
            if (CurrentUser is null)
            {
                SecurityError = L["AccountMissingError"];
                return;
            }

            var verificationCode = (MfaModel.VerificationCode ?? string.Empty)
                .Replace(" ", string.Empty, StringComparison.Ordinal)
                .Replace("-", string.Empty, StringComparison.Ordinal);

            var isValid = await UserManager.VerifyTwoFactorTokenAsync(
                CurrentUser,
                UserManager.Options.Tokens.AuthenticatorTokenProvider,
                verificationCode);

            if (!isValid)
            {
                SecurityError = "The authenticator code is not valid.";
                return;
            }

            await UserManager.SetTwoFactorEnabledAsync(CurrentUser, true);
            var claims = await UserManager.GetClaimsAsync(CurrentUser);
            foreach (var claim in claims.Where(claim => string.Equals(claim.Type, IdentityClaimTypes.MfaSetupRequired, StringComparison.Ordinal)))
            {
                await UserManager.RemoveClaimAsync(CurrentUser, claim);
            }

            RecoveryCodes = (await UserManager.GenerateNewTwoFactorRecoveryCodesAsync(CurrentUser, 8) ?? Array.Empty<string>()).ToList();
            await SignInManager.RefreshSignInAsync(CurrentUser);
            MfaModel = new MfaEnrollmentInput();
            MfaSuccess = "Two-factor authentication is now enabled.";
            await LoadSecurityStateAsync();
        }
        catch (Exception ex)
        {
            SecurityError = ex.Message;
        }
        finally
        {
            IsSavingMfa = false;
        }
    }

    private string TabClass(string tab) =>
        ActiveTab == tab ? "tab-chip active" : "tab-chip";

    private string FormatPreviewTime()
    {
        return PreferenceModel.TimeZone switch
        {
            "Europe/London" => DateTimeOffset.UtcNow.ToOffset(TimeSpan.Zero).ToString("HH:mm 'UTC'"),
            "Europe/Istanbul" => DateTimeOffset.UtcNow.ToOffset(TimeSpan.FromHours(3)).ToString("HH:mm 'UTC+3'"),
            "America/New_York" => DateTimeOffset.UtcNow.ToOffset(TimeSpan.FromHours(-4)).ToString("HH:mm 'UTC-4'"),
            _ => DateTimeOffset.UtcNow.ToString("HH:mm 'UTC'"),
        };
    }

    private sealed class PasswordChangeInput
    {
        [Required]
        public string CurrentPassword { get; set; } = string.Empty;

        [Required]
        [MinLength(8)]
        public string NewPassword { get; set; } = string.Empty;

        [Required]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    private static string FormatAuthenticatorKey(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return string.Join(" ", Enumerable.Range(0, (value.Length + 3) / 4)
            .Select(index =>
            {
                var start = index * 4;
                var length = Math.Min(4, value.Length - start);
                return value.Substring(start, length).ToLowerInvariant();
            }));
    }

    private sealed class MfaEnrollmentInput
    {
        [Required]
        public string VerificationCode { get; set; } = string.Empty;
    }

    private sealed class UserPreferenceInput
    {
        public string Language { get; set; } = "en-GB";
        public string TimeZone { get; set; } = "Europe/London";
        public string Density { get; set; } = "compact";
    }
}
