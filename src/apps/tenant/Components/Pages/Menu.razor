@page "/menu"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IStringLocalizer<TenantText> L
@inject CustomerSessionBrowserStore CustomerSessionStore

<PageTitle>@L["MenuTitle"]</PageTitle>

<section class="page-hero">
    <div>
        <p class="eyebrow">@L["NavMenu"]</p>
        <h1>@L["MenuTitle"]</h1>
        <p class="hero-copy">@L["MenuHero"]</p>
    </div>
    @if (HasSession)
    {
        <div class="hero-actions">
            <span class="status-pill success">@TableLabel</span>
            <a href="/cart" class="btn btn-primary">@L["ViewCart"]</a>
        </div>
    }
</section>

@if (!HasSession)
{
    <section class="empty-state">
        <h3>@L["NoActiveSession"]</h3>
        <p>@L["ScanQrToStart"]</p>
        <a href="/scan-qr" class="btn btn-primary">@L["NavScanQr"]</a>
    </section>
}
else if (MenuItems is null)
{
    <section class="empty-state">
        <h3>@L["LoadingMenu"]</h3>
        <p>@L["LoadingMenuCopy"]</p>
    </section>
}
else if (MenuItems.Count == 0)
{
    <section class="empty-state">
        <h3>@L["MenuEmpty"]</h3>
        <p>@L["MenuEmptyCopy"]</p>
    </section>
}
else
{
    <section class="entity-grid">
        @foreach (var item in MenuItems)
        {
            <article class="entity-card">
                <div class="entity-card-top">
                    <div>
                        <p class="eyebrow">@L["NavMenu"]</p>
                        <h3>@item.Name</h3>
                    </div>
                    <span class="status-pill neutral">@item.Price.ToString("C")</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(item.Description))
                {
                    <p class="entity-meta">@item.Description</p>
                }
                <div class="form-actions">
                    <button class="btn btn-primary" @onclick="() => AddToCart(item.Id)">@L["AddToCart"]</button>
                </div>
            </article>
        }
    </section>
}

@code {
    private List<MenuItemDto>? MenuItems = [];
    private Guid? CurrentSessionId;
    private string TableLabel = string.Empty;
    private bool HasSession;

    protected override async Task OnInitializedAsync()
    {
        var snapshot = await CustomerSessionStore.GetSnapshotAsync();
        var sessionId = snapshot.SessionId;
        var tableLabel = snapshot.TableLabel;

        if (!string.IsNullOrEmpty(sessionId))
        {
            CurrentSessionId = Guid.Parse(sessionId);
            TableLabel = tableLabel ?? string.Empty;
            HasSession = true;
            MenuItems = await Http.GetFromJsonAsync<List<MenuItemDto>>("/api/menu");
        }
    }

    private async Task AddToCart(Guid itemId)
    {
        if (CurrentSessionId is null)
        {
            NavigationManager.NavigateTo("/scan-qr");
            return;
        }

        var request = new AddCartItemRequest(CurrentSessionId.Value, itemId, 1);
        await Http.PostAsJsonAsync("/api/public/cart", request);
        NavigationManager.NavigateTo("/cart");
    }

    private record MenuItemDto(Guid Id, string Name, decimal Price, string? Description, Guid CategoryId);
    private record AddCartItemRequest(Guid SessionId, Guid MenuItemId, int Quantity, string? Note = null);
}
