@page "/kitchen"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = "Tenant:Read")]
@inject IStringLocalizer<TenantText> L
@inject DialogService DialogService
@inject IKitchenReadService KitchenReadService

<PageTitle>@L["KitchenTitle"]</PageTitle>
<RadzenComponents />

<SectionContent SectionName="tenant-header">
    <div>
        <p class="eyebrow">@L["NavKitchen"]</p>
        <h2>@L["KitchenTitle"]</h2>
        <p class="hero-copy">@L["KitchenHero"]</p>
    </div>
</SectionContent>

<SectionContent SectionName="tenant-inspector">
    @if (SelectedOrder is null)
    {
        <div class="console-context">
            <section class="context-card">
                <h4>@L["NoOrderSelected"]</h4>
                <p class="detail-copy">@L["NoOrderSelectedCopy"]</p>
            </section>
        </div>
    }
    else
    {
        <div class="console-context">
            <section class="context-card">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">@SelectedOrder.TableLabel</p>
                        <h3>#@SelectedOrder.Id.ToString()[..8]</h3>
                    </div>
                    <span class="status-pill warning">@($"{SelectedOrder.Items.Count} {L["TableItem"]}")</span>
                </div>

                <div class="kv-grid">
                    <div class="kv-item">
                        <span class="kv-label">@L["SubmittedAt"]</span>
                        <span class="kv-value">@SelectedOrder.SubmittedAt.LocalDateTime.ToString("g")</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-label">@L["TableTotal"]</span>
                        <span class="kv-value">@SelectedOrder.TotalAmount.ToString("C")</span>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(SelectedOrder.Note))
                {
                    <section class="detail-section">
                        <p class="detail-title">@L["OrderNote"]</p>
                        <p class="detail-copy">@SelectedOrder.Note</p>
                    </section>
                }

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="() => OpenInspectorAsync(SelectedOrder)">@L["OpenInspector"]</button>
                </div>
            </section>
        </div>
    }
</SectionContent>

@if (Orders is null)
{
    <section class="empty-state">
        <h3>@L["LoadingKitchen"]</h3>
        <p>@L["LoadingKitchenCopy"]</p>
    </section>
}
else if (Orders.Count == 0)
{
    <section class="empty-state">
        <h3>@L["NoKitchenOrders"]</h3>
        <p>@L["NoKitchenOrdersCopy"]</p>
    </section>
}
else
{
    <section class="entity-grid">
        @foreach (var order in Orders)
        {
            var isSelected = order.Id == SelectedOrderId;
            <article class="entity-card @(isSelected ? "selected-surface" : null)" @onclick="() => SelectOrder(order.Id)">
                <div class="entity-card-top">
                    <div>
                        <p class="eyebrow">@order.TableLabel</p>
                        <h3>#@order.Id.ToString()[..8]</h3>
                    </div>
                    <span class="status-pill warning">@($"{order.Items.Count} {L["TableItem"]}")</span>
                </div>

                <p class="entity-meta">@order.SubmittedAt.LocalDateTime.ToString("g") · @order.TotalAmount.ToString("C")</p>

                @if (!string.IsNullOrWhiteSpace(order.Note))
                {
                    <p class="detail-copy">@order.Note</p>
                }

                <div class="chip-row">
                    @foreach (var item in order.Items.Take(3))
                    {
                        <span class="status-pill neutral">@($"{item.ItemName} x{item.Quantity}")</span>
                    }
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="() => OpenInspectorAsync(order)">
                        @L["OpenInspector"]
                    </button>
                </div>
            </article>
        }
    </section>
}

@code {
    private List<KitchenOrderDto>? Orders;
    private Guid? SelectedOrderId;
    private KitchenOrderDto? SelectedOrder => Orders?.FirstOrDefault(order => order.Id == SelectedOrderId) ?? Orders?.FirstOrDefault();

    protected override async Task OnInitializedAsync()
    {
        Orders = (await KitchenReadService.GetOrdersInProgressAsync()).ToList();
        SelectedOrderId ??= Orders.FirstOrDefault()?.Id;
    }

    private void SelectOrder(Guid orderId) => SelectedOrderId = orderId;

    private async Task OpenInspectorAsync(KitchenOrderDto order)
    {
        await DialogService.OpenSideAsync(
            L["KitchenDrawerTitle"],
            typeof(KitchenOrderPanel),
            new Dictionary<string, object?>
            {
                [nameof(KitchenOrderPanel.Order)] = new KitchenOrderPanel.KitchenOrderDto(
                    order.Id,
                    order.TableLabel,
                    order.TotalAmount,
                    order.SubmittedAt,
                    order.Note,
                    order.Items.Select(item => new KitchenOrderPanel.KitchenItemDto(item.Id, item.ItemName, item.Quantity, item.Status, item.Note)).ToList()),
                [nameof(KitchenOrderPanel.ReloadRequested)] = EventCallback.Factory.Create(this, OnInitializedAsync)
            },
            new SideDialogOptions
            {
                Position = DialogPosition.Right,
                Width = "460px",
                ShowMask = true
            });
    }

}
