@page "/table/{tableNumber:int}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Tenant:Read")]

<PageTitle>Table @TableNumber</PageTitle>

<h1>Table @TableNumber</h1>

<div class="table-info">
    <p>Status: @TableStatus</p>
    <p>Current Session: @CurrentSessionId</p>
</div>

<div class="session-actions">
    @if (TableStatus == "Available")
    {
        <button class="btn btn-primary">Start Session</button>
    }
    else
    {
        <button class="btn btn-secondary">End Session</button>
    }
</div>

@code {
    [Parameter]
    public int TableNumber { get; set; }

    private string TableStatus = "Available";
    private string CurrentSessionId = "None";

    protected override async Task OnInitializedAsync()
    {
        // TODO(TD-0019): Load from database
    }
}
