@page "/cart"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IStringLocalizer<TenantText> L
@inject CustomerSessionBrowserStore CustomerSessionStore
@inject DialogService DialogService
@using System.Globalization

<PageTitle>@L["CartTitle"]</PageTitle>
<RadzenComponents />

<section class="page-hero">
    <div>
        <p class="eyebrow">@L["NavCart"]</p>
        <h1>@L["CartTitle"]</h1>
        <p class="hero-copy">@L["CartHero"]</p>
    </div>
</section>

@if (!HasSession)
{
    <section class="empty-state">
        <h3>@L["NoActiveSession"]</h3>
        <p>@L["ScanQrToStart"]</p>
        <a href="/scan-qr" class="btn btn-primary">@L["NavScanQr"]</a>
    </section>
}
else if (CartItems is null)
{
    <section class="empty-state">
        <h3>@L["LoadingCart"]</h3>
        <p>@L["LoadingCartCopy"]</p>
    </section>
}
else if (CartItems.Count == 0)
{
    <section class="empty-state">
        <h3>@L["CartEmpty"]</h3>
        <p>@L["CartEmptyCopy"]</p>
        <a href="/menu" class="btn btn-secondary">@L["NavMenu"]</a>
    </section>
}
else
{
    <section class="panel">
        <table class="table">
            <thead>
                <tr>
                    <th>@L["TableItem"]</th>
                    <th>@L["TableQuantity"]</th>
                    <th>@L["TablePrice"]</th>
                    <th>@L["TableTotal"]</th>
                    <th>@L["TableActions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in CartItems)
                {
                    <tr>
                        <td>@item.MenuItemName</td>
                        <td>@item.Quantity</td>
                        <td>@item.UnitPrice.ToString("C")</td>
                        <td>@(item.UnitPrice * item.Quantity).ToString("C")</td>
                        <td>
                            <button class="btn btn-sm btn-danger" @onclick="() => RemoveItem(item.Id)">@L["Remove"]</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="cart-summary">
            <p>@TableLabel · @L["TableTotal"]: @Total.ToString("C")</p>
            <button class="btn btn-primary" @onclick="OpenCheckoutAsync">@L["PlaceOrder"]</button>
        </div>
    </section>
}

@code {
    private List<CartItemDto>? CartItems = [];
    private decimal Total;
    private Guid? CurrentSessionId;
    private Guid? CurrentTicketId;
    private Guid? CurrentTableId;
    private string TableLabel = string.Empty;
    private bool HasSession;

    protected override async Task OnInitializedAsync()
    {
        await LoadSessionAsync();
    }

    private async Task LoadSessionAsync()
    {
        var snapshot = await CustomerSessionStore.GetSnapshotAsync();

        if (Guid.TryParse(snapshot.SessionId, out var sessionId))
        {
            CurrentSessionId = sessionId;
            HasSession = true;
        }

        if (Guid.TryParse(snapshot.TicketId, out var ticketId))
        {
            CurrentTicketId = ticketId;
        }

        if (Guid.TryParse(snapshot.TableId, out var tableId))
        {
            CurrentTableId = tableId;
        }

        TableLabel = snapshot.TableLabel ?? string.Empty;

        if (CurrentTicketId is not null && (CurrentTableId is null || string.IsNullOrWhiteSpace(TableLabel)))
        {
            var sessionState = await Http.GetFromJsonAsync<CustomerSessionStateDto>($"/api/public/session/{CurrentTicketId}");
            if (sessionState is not null)
            {
                CurrentSessionId = sessionState.SessionId;
                CurrentTicketId = sessionState.TicketId;
                CurrentTableId = sessionState.TableId;
                TableLabel = sessionState.TableLabel;
                HasSession = true;

                await CustomerSessionStore.SetSnapshotAsync(
                    sessionState.SessionId,
                    sessionState.TicketId,
                    sessionState.TableId,
                    sessionState.TableLabel);
            }
        }

        if (CurrentSessionId is not null)
        {
            CartItems = await Http.GetFromJsonAsync<List<CartItemDto>>($"/api/public/cart/session/{CurrentSessionId.Value}");
            Total = CartItems?.Sum(ci => ci.UnitPrice * ci.Quantity) ?? 0;
        }
    }

    private async Task RemoveItem(Guid id)
    {
        await Http.DeleteAsync($"/api/public/cart/{id}");
        await LoadSessionAsync();
    }

    private async Task OpenCheckoutAsync()
    {
        if (CurrentSessionId is null || CurrentTicketId is null || CurrentTableId is null)
        {
            NavigationManager.NavigateTo("/scan-qr");
            return;
        }

        var result = await DialogService.OpenSideAsync<CheckoutPanel>(
            L["CheckoutDrawerTitle"],
            new Dictionary<string, object?>
            {
                [nameof(CheckoutPanel.SessionId)] = CurrentSessionId.Value,
                [nameof(CheckoutPanel.TicketId)] = CurrentTicketId.Value,
                [nameof(CheckoutPanel.TableId)] = CurrentTableId.Value,
                [nameof(CheckoutPanel.TableLabel)] = TableLabel,
                [nameof(CheckoutPanel.TotalAmount)] = Total,
            },
            new SideDialogOptions
            {
                Position = DialogPosition.Right,
                Width = "460px",
                ShowMask = true
            });

        if (result is CheckoutPanel.SubmitOrderResult orderResult)
        {
            await CustomerSessionStore.ClearAsync();
            var total = Uri.EscapeDataString(orderResult.TotalAmount.ToString(CultureInfo.InvariantCulture));
            var table = Uri.EscapeDataString(TableLabel);
            NavigationManager.NavigateTo($"/order-complete/{orderResult.OrderId}?total={total}&table={table}");
        }
    }

    private record CartItemDto(Guid Id, Guid MenuItemId, string MenuItemName, int Quantity, decimal UnitPrice, string? Note);
    private record CustomerSessionStateDto(Guid SessionId, Guid TicketId, Guid TableId, string TableLabel, IReadOnlyList<CartItemSummaryDto> CartItems);
    private record CartItemSummaryDto(Guid ItemId, string ItemName, int Quantity, decimal UnitPrice, string? Note);
}
