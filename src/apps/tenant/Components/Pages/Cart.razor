@page "/cart"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject IStringLocalizer<TenantText> L

<PageTitle>@L["CartTitle"]</PageTitle>

<section class="page-hero">
    <div>
        <p class="eyebrow">@L["NavCart"]</p>
        <h1>@L["CartTitle"]</h1>
        <p class="hero-copy">@L["CartHero"]</p>
    </div>
</section>

@if (!HasSession)
{
    <section class="empty-state">
        <h3>@L["NoActiveSession"]</h3>
        <p>@L["ScanQrToStart"]</p>
        <a href="/scan-qr" class="btn btn-primary">@L["NavScanQr"]</a>
    </section>
}
else if (CartItems is null)
{
    <section class="empty-state">
        <h3>@L["LoadingCart"]</h3>
        <p>@L["LoadingCartCopy"]</p>
    </section>
}
else if (CartItems.Count == 0)
{
    <section class="empty-state">
        <h3>@L["CartEmpty"]</h3>
        <p>@L["CartEmptyCopy"]</p>
        <a href="/menu" class="btn btn-secondary">@L["NavMenu"]</a>
    </section>
}
else
{
    <section class="panel">
        <table class="table">
            <thead>
                <tr>
                    <th>@L["TableItem"]</th>
                    <th>@L["TableQuantity"]</th>
                    <th>@L["TablePrice"]</th>
                    <th>@L["TableTotal"]</th>
                    <th>@L["TableActions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in CartItems)
                {
                    <tr>
                        <td>@item.MenuItemName</td>
                        <td>@item.Quantity</td>
                        <td>@item.UnitPrice.ToString("C")</td>
                        <td>@(item.UnitPrice * item.Quantity).ToString("C")</td>
                        <td>
                            <button class="btn btn-sm btn-danger" @onclick="() => RemoveItem(item.Id)">@L["Remove"]</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="cart-summary">
            <p>@L["TableTotal"]: @Total.ToString("C")</p>
            <button class="btn btn-primary" @onclick="SubmitOrder">@L["PlaceOrder"]</button>
        </div>
    </section>
}

@code {
    private List<CartItemDto>? CartItems = [];
    private decimal Total;
    private Guid? CurrentSessionId;
    private string TableLabel = string.Empty;
    private bool HasSession;

    protected override async Task OnInitializedAsync()
    {
        var sessionId = await JS.InvokeAsync<string?>("localStorage.getItem", "sessionId");
        var tableLabel = await JS.InvokeAsync<string?>("localStorage.getItem", "tableLabel");

        if (!string.IsNullOrEmpty(sessionId))
        {
            CurrentSessionId = Guid.Parse(sessionId);
            TableLabel = tableLabel ?? string.Empty;
            HasSession = true;

            CartItems = await Http.GetFromJsonAsync<List<CartItemDto>>($"/api/public/cart/session/{CurrentSessionId}");
            Total = CartItems?.Sum(ci => ci.UnitPrice * ci.Quantity) ?? 0;
        }
    }

    private async Task RemoveItem(Guid id)
    {
        await Http.DeleteAsync($"/api/public/cart/{id}");
        await OnInitializedAsync();
    }

    private async Task SubmitOrder()
    {
        if (CurrentSessionId is null)
        {
            NavigationManager.NavigateTo("/scan-qr");
            return;
        }

        var ticketId = await JS.InvokeAsync<string?>("localStorage.getItem", "ticketId");
        if (string.IsNullOrEmpty(ticketId))
        {
            NavigationManager.NavigateTo("/scan-qr");
            return;
        }

        var request = new SubmitOrderRequest(
            CurrentSessionId.Value,
            Guid.Parse(ticketId),
            Guid.Empty,
            "checkout-proof-token",
            Guid.NewGuid().ToString(),
            null);

        var result = await Http.PostAsJsonAsync("/api/public/orders", request);
        if (result.IsSuccessStatusCode)
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", "ticketId");
            await JS.InvokeVoidAsync("localStorage.removeItem", "sessionId");
            await JS.InvokeVoidAsync("localStorage.removeItem", "tableLabel");
            NavigationManager.NavigateTo("/menu");
        }
    }

    private record CartItemDto(Guid Id, Guid MenuItemId, string MenuItemName, int Quantity, decimal UnitPrice, string? Note);
    private record SubmitOrderRequest(Guid SessionId, Guid TicketId, Guid TableId, string CheckoutProofToken, string IdempotencyKey, string? Note);
}
