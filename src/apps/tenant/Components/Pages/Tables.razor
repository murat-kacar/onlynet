@page "/tables"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = "Tenant:Read")]
@inject HttpClient Http
@inject IStringLocalizer<TenantText> L
@inject DialogService DialogService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@L["TablesTitle"]</PageTitle>
<RadzenComponents />

<section class="page-hero">
    <div>
        <p class="eyebrow">@L["NavTables"]</p>
        <h1>@L["TablesTitle"]</h1>
        <p class="hero-copy">@L["TablesHero"]</p>
    </div>
    @if (CanWrite)
    {
        <div class="hero-actions">
            <button type="button" class="btn btn-primary" @onclick="OpenCreateAsync">@L["CreateTable"]</button>
        </div>
    }
</section>

@if (TableList is null)
{
    <section class="empty-state">
        <h3>@L["LoadingTables"]</h3>
        <p>@L["LoadingTablesCopy"]</p>
    </section>
}
else if (TableList.Count == 0)
{
    <section class="empty-state">
        <h3>@L["NoTables"]</h3>
        <p>@L["NoTablesCopy"]</p>
    </section>
}
else
{
    <section class="entity-grid">
        @foreach (var table in TableList)
        {
            <article class="entity-card">
                <div class="entity-card-top">
                    <div>
                        <p class="eyebrow">@(table.HasOpenSession ? L["SessionLive"] : (table.IsActive ? L["Active"] : L["Inactive"]))</p>
                        <h3>@table.Name</h3>
                    </div>
                    <span class="status-pill @(table.HasOpenSession ? "warning" : (table.IsActive ? "success" : "neutral"))">
                        @(table.HasOpenSession ? L["SessionLive"] : (table.IsActive ? L["Active"] : L["Inactive"]))
                    </span>
                </div>

                <div class="kv-grid compact-kv">
                    <div class="kv-item">
                        <span class="kv-label">@L["TableCode"]</span>
                        <span class="kv-value">@table.Code</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-label">@L["OpenSessionState"]</span>
                        <span class="kv-value">@(table.HasOpenSession ? L["Live"] : L["Inactive"])</span>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="() => OpenInspectorAsync(table.Id)">
                        @L["OpenInspector"]
                    </button>
                    @if (CanWrite)
                    {
                        <button type="button" class="btn btn-secondary" @onclick="() => OpenEditorAsync(table.Id)">
                            @L["EditTable"]
                        </button>
                    }
                </div>
            </article>
        }
    </section>
}

@code {
    private List<TableDto>? TableList;
    private bool CanWrite;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        CanWrite = authState.User.HasClaim("TenantRole", "Write");
        await ReloadAsync();
    }

    private async Task OpenInspectorAsync(Guid tableId)
    {
        var workspace = await Http.GetFromJsonAsync<TableWorkspaceDto>($"/api/tables/{tableId}/workspace");
        if (workspace is null)
        {
            return;
        }

        await DialogService.OpenSideAsync(
            $"{L["TableDrawerTitle"]} · {workspace.Name}",
            typeof(TableInspectorPanel),
            new Dictionary<string, object?>
            {
                [nameof(TableInspectorPanel.Workspace)] = workspace,
                [nameof(TableInspectorPanel.ReloadRequested)] = EventCallback.Factory.Create(this, ReloadAsync)
            },
            new SideDialogOptions
            {
                Position = DialogPosition.Right,
                Width = "480px",
                ShowMask = true
            });
    }

    private async Task ReloadAsync()
    {
        TableList = await Http.GetFromJsonAsync<List<TableDto>>("/api/tables");
        StateHasChanged();
    }

    private async Task OpenCreateAsync()
    {
        await DialogService.OpenSideAsync<TableEditorPanel>(
            L["CreateTable"],
            new Dictionary<string, object?>
            {
                [nameof(TableEditorPanel.ReloadRequested)] = EventCallback.Factory.Create(this, ReloadAsync)
            },
            new SideDialogOptions
            {
                Position = DialogPosition.Right,
                Width = "460px",
                ShowMask = true
            });
    }

    private async Task OpenEditorAsync(Guid tableId)
    {
        var detail = await Http.GetFromJsonAsync<TableDetailRecord>($"/api/tables/{tableId}");
        if (detail is null)
        {
            return;
        }

        await DialogService.OpenSideAsync<TableEditorPanel>(
            $"{L["EditTable"]} · {detail.Name}",
            new Dictionary<string, object?>
            {
                [nameof(TableEditorPanel.Table)] = new TableEditorPanel.TableRecord(
                    detail.Id,
                    detail.Name,
                    detail.Code,
                    detail.Color,
                    detail.Type,
                    detail.IsActive,
                    detail.SortOrder),
                [nameof(TableEditorPanel.ReloadRequested)] = EventCallback.Factory.Create(this, ReloadAsync)
            },
            new SideDialogOptions
            {
                Position = DialogPosition.Right,
                Width = "460px",
                ShowMask = true
            });
    }

    private record TableDto(Guid Id, string Name, string Code, bool IsActive, int SortOrder, bool HasOpenSession);
    private record TableDetailRecord(Guid Id, string Name, string Code, string Color, string Type, bool IsActive, int SortOrder, bool IsOccupied);
    private record TableWorkspaceDto(Guid Id, string Name, string Code, string Color, string Type, bool IsActive, int SortOrder, bool HasOpenSession, TableSessionWorkspaceDto? Session);
    private record TableSessionWorkspaceDto(Guid SessionId, Guid TableId, DateTimeOffset OpenedAt, int TicketCount, IReadOnlyList<TableCartItemDto> CartItems, IReadOnlyList<TableSessionOrderDto> Orders);
    private record TableCartItemDto(Guid Id, string ItemName, int Quantity, decimal UnitPrice, string? Note);
    private record TableSessionOrderDto(Guid Id, decimal TotalAmount, DateTimeOffset SubmittedAt, int ItemCount);
}
