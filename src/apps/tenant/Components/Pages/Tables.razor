@page "/tables"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = "Tenant:Read")]
@inject HttpClient Http
@inject IStringLocalizer<TenantText> L
@inject DialogService DialogService

<PageTitle>@L["TablesTitle"]</PageTitle>
<RadzenComponents />

<section class="page-hero">
    <div>
        <p class="eyebrow">@L["NavTables"]</p>
        <h1>@L["TablesTitle"]</h1>
        <p class="hero-copy">@L["TablesHero"]</p>
    </div>
</section>

@if (TableList is null)
{
    <section class="empty-state">
        <h3>@L["LoadingTables"]</h3>
        <p>@L["LoadingTablesCopy"]</p>
    </section>
}
else if (TableList.Count == 0)
{
    <section class="empty-state">
        <h3>@L["NoTables"]</h3>
        <p>@L["NoTablesCopy"]</p>
    </section>
}
else
{
    <section class="entity-grid">
        @foreach (var table in TableList)
        {
            <article class="entity-card">
                <div class="entity-card-top">
                    <div>
                        <p class="eyebrow">@(table.IsActive ? L["Active"] : L["Inactive"])</p>
                        <h3>@table.Name</h3>
                    </div>
                    <span class="status-pill @(table.IsActive ? "success" : "neutral")">@(table.IsActive ? L["Active"] : L["Inactive"])</span>
                </div>

                <div class="kv-grid compact-kv">
                    <div class="kv-item">
                        <span class="kv-label">@L["TableCode"]</span>
                        <span class="kv-value">@table.Code</span>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="() => OpenInspectorAsync(table.Id)">
                        @L["OpenInspector"]
                    </button>
                </div>
            </article>
        }
    </section>
}

@code {
    private List<TableDto>? TableList;

    protected override async Task OnInitializedAsync()
    {
        TableList = await Http.GetFromJsonAsync<List<TableDto>>("/api/tables");
    }

    private async Task OpenInspectorAsync(Guid tableId)
    {
        var detail = await Http.GetFromJsonAsync<TableDetailDto>($"/api/tables/{tableId}");
        if (detail is null)
        {
            return;
        }

        await DialogService.OpenSideAsync(
            L["TableDrawerTitle"],
            typeof(TableInspectorPanel),
            new Dictionary<string, object?>
            {
                [nameof(TableInspectorPanel.Detail)] = new TableInspectorPanel.TableDetailDto(
                    detail.Id,
                    detail.Name,
                    detail.Code,
                    detail.Color,
                    detail.Type,
                    detail.IsActive,
                    detail.SortOrder,
                    detail.HasOpenSession)
            },
            new SideDialogOptions
            {
                Position = DialogPosition.Right,
                Width = "420px",
                ShowMask = true
            });
    }

    private record TableDto(Guid Id, string Name, string Code, bool IsActive, int SortOrder);
    private record TableDetailDto(Guid Id, string Name, string Code, string Color, string Type, bool IsActive, int SortOrder, bool HasOpenSession);
}
