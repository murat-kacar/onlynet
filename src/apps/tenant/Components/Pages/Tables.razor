@page "/tables"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = "Tenant:Read")]
@inject IStringLocalizer<TenantText> L
@inject DialogService DialogService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ITableReadService TableReadService

<PageTitle>@L["TablesTitle"]</PageTitle>
<RadzenComponents />

<SectionContent SectionName="tenant-header">
    <div>
        <p class="eyebrow">@L["NavTables"]</p>
        <h2>@L["TablesTitle"]</h2>
        <p class="hero-copy">@L["TablesHero"]</p>
    </div>
</SectionContent>

<SectionContent SectionName="tenant-header-actions">
    @if (CanWrite)
    {
        <button type="button" class="btn btn-primary" @onclick="OpenCreateAsync">@L["CreateTable"]</button>
    }
</SectionContent>

<SectionContent SectionName="tenant-inspector">
    @if (SelectedTable is null)
    {
        <div class="console-context">
            <section class="context-card">
                <h4>@L["NoTableSelected"]</h4>
                <p class="detail-copy">@L["TablesNoTableSelectedCopy"]</p>
            </section>
        </div>
    }
    else
    {
        <div class="console-context">
            <section class="context-card">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">@L["Selection"]</p>
                        <h3>@SelectedTable.Name</h3>
                    </div>
                    <span class="status-pill @(SelectedTable.HasOpenSession ? "warning" : (SelectedTable.IsActive ? "success" : "neutral"))">
                        @(SelectedTable.IsActive ? L["Active"] : L["Inactive"])
                    </span>
                </div>

                <div class="kv-grid">
                    <div class="kv-item">
                        <span class="kv-label">@L["TableCode"]</span>
                        <span class="kv-value">@SelectedTable.Code</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-label">@L["SortOrder"]</span>
                        <span class="kv-value">@SelectedTable.SortOrder</span>
                    </div>
                </div>

                <div class="form-actions">
                    @if (CanWrite)
                    {
                        <button type="button" class="btn btn-primary" @onclick="() => OpenEditorAsync(SelectedTable.Id)">@L["EditTable"]</button>
                    }
                </div>
            </section>
        </div>
    }
</SectionContent>

@if (TableList is null)
{
    <section class="empty-state">
        <h3>@L["LoadingTables"]</h3>
        <p>@L["LoadingTablesCopy"]</p>
    </section>
}
else if (TableList.Count == 0)
{
    <section class="empty-state">
        <h3>@L["NoTables"]</h3>
        <p>@L["NoTablesCopy"]</p>
    </section>
}
else
{
    <section class="entity-grid">
        @foreach (var table in TableList)
        {
            var isSelected = table.Id == SelectedTableId;
            <article class="entity-card @(isSelected ? "selected-surface" : null)" @onclick="() => SelectTable(table.Id)">
                <div class="entity-card-top">
                    <div>
                        <p class="eyebrow">@L["TableSetup"]</p>
                        <h3>@table.Name</h3>
                    </div>
                    <span class="status-pill @(table.IsActive ? "success" : "neutral")">
                        @(table.IsActive ? L["Active"] : L["Inactive"])
                    </span>
                </div>

                <div class="kv-grid compact-kv">
                    <div class="kv-item">
                        <span class="kv-label">@L["TableCode"]</span>
                        <span class="kv-value">@table.Code</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-label">@L["SortOrder"]</span>
                        <span class="kv-value">@table.SortOrder</span>
                    </div>
                </div>

                <div class="form-actions">
                    @if (CanWrite)
                    {
                        <button type="button" class="btn btn-secondary" @onclick="() => OpenEditorAsync(table.Id)">
                            @L["EditTable"]
                        </button>
                    }
                </div>
            </article>
        }
    </section>
}

@code {
    private List<TableDto>? TableList;
    private bool CanWrite;
    private Guid? SelectedTableId;
    private TableDto? SelectedTable => TableList?.FirstOrDefault(table => table.Id == SelectedTableId) ?? TableList?.FirstOrDefault();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        CanWrite = authState.User.HasClaim("TenantRole", "Write");
        await ReloadAsync();
    }

    private void SelectTable(Guid tableId) => SelectedTableId = tableId;

    private async Task ReloadAsync()
    {
        TableList = (await TableReadService.GetTablesAsync()).ToList();
        SelectedTableId ??= TableList.FirstOrDefault()?.Id;
        StateHasChanged();
    }

    private async Task OpenCreateAsync()
    {
        await DialogService.OpenSideAsync<TableEditorPanel>(
            L["CreateTable"],
            new Dictionary<string, object?>
            {
                [nameof(TableEditorPanel.ReloadRequested)] = EventCallback.Factory.Create(this, ReloadAsync)
            },
            new SideDialogOptions
            {
                Position = DialogPosition.Right,
                Width = "460px",
                ShowMask = true
            });
    }

    private async Task OpenEditorAsync(Guid tableId)
    {
        var detail = await TableReadService.GetTableAsync(tableId);
        if (detail is null)
        {
            return;
        }

        await DialogService.OpenSideAsync<TableEditorPanel>(
            $"{L["EditTable"]} · {detail.Name}",
            new Dictionary<string, object?>
            {
                [nameof(TableEditorPanel.Table)] = new TableEditorPanel.TableRecord(
                    detail.Id,
                    detail.Name,
                    detail.Code,
                    detail.Color,
                    detail.Type,
                    detail.IsActive,
                    detail.SortOrder),
                [nameof(TableEditorPanel.ReloadRequested)] = EventCallback.Factory.Create(this, ReloadAsync)
            },
            new SideDialogOptions
            {
                Position = DialogPosition.Right,
                Width = "460px",
                ShowMask = true
            });
    }

    private sealed record TableRecord(Guid Id, string Name, string Code, string Color, string Type, bool IsActive, int SortOrder);
}
