@page "/scan-qr"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject IStringLocalizer<TenantText> L
@inject CustomerSessionBrowserStore CustomerSessionStore

<PageTitle>@L["ScanQrTitle"]</PageTitle>

<section class="page-hero">
    <div>
        <p class="eyebrow">@L["NavScanQr"]</p>
        <h1>@L["ScanQrTitle"]</h1>
        <p class="hero-copy">@L["ScanQrHero"]</p>
    </div>
</section>

<section class="panel auth-panel">
    <div class="detail-layout scanner-layout">
        <section class="panel detail-panel">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">@L["CameraScan"]</p>
                    <h3>@L["ScanQrTitle"]</h3>
                </div>
            </div>

            <div class="scanner-frame">
                <video @ref="VideoElement" class="scanner-video" autoplay muted playsinline></video>
            </div>

            @if (CameraMessage is not null)
            {
                <p class="detail-copy">@CameraMessage</p>
            }

            <div class="form-actions">
                <button class="btn btn-primary" disabled="@IsOpeningSession" @onclick="StartCameraAsync">@L["StartCameraScan"]</button>
                <button class="btn btn-secondary" @onclick="StopCameraAsync">@L["StopCameraScan"]</button>
            </div>
        </section>

        <section class="panel detail-panel">
            <div class="qr-input">
                <label>@L["EnterQrToken"]</label>
                <input type="text" @bind="QrToken" placeholder="QR Token" />
                <div class="form-actions">
                    <button class="btn btn-primary" disabled="@IsOpeningSession" @onclick="OpenSession">@L["OpenSession"]</button>
                    <button class="btn btn-secondary" @onclick="ResetScan">@L["ScanAgain"]</button>
                </div>
            </div>
        </section>
    </div>
</section>

@if (ErrorMessage is not null)
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

@code {
    private string QrToken = string.Empty;
    private string? ErrorMessage;
    private string? CameraMessage;
    private bool IsOpeningSession;
    private ElementReference VideoElement;
    private IJSObjectReference? ScannerModule;
    private DotNetObjectReference<ScanQr>? DotNetRef;

    protected override async Task OnInitializedAsync()
    {
        var existingTicketId = (await CustomerSessionStore.GetSnapshotAsync()).TicketId;
        if (!string.IsNullOrEmpty(existingTicketId))
        {
            NavigationManager.NavigateTo("/menu");
        }
    }

    private void ResetScan()
    {
        QrToken = string.Empty;
        ErrorMessage = null;
    }

    private async Task OpenSession()
    {
        await OpenSessionAsync(QrToken);
    }

    [JSInvokable]
    public async Task HandleDetectedQrToken(string token)
    {
        QrToken = token;
        await InvokeAsync(StateHasChanged);
        await OpenSessionAsync(token);
    }

    private async Task OpenSessionAsync(string token)
    {
        if (string.IsNullOrWhiteSpace(token))
        {
            ErrorMessage = L["QrRequired"];
            return;
        }

        IsOpeningSession = true;

        try
        {
            var result = await Http.PostAsJsonAsync("/api/public/session/open", new { QrTokenValue = token.Trim() });
            result.EnsureSuccessStatusCode();

            var sessionResult = await result.Content.ReadFromJsonAsync<OpenSessionResult>();
            if (sessionResult is not null)
            {
                await StopCameraAsync();
                await CustomerSessionStore.SetSnapshotAsync(
                    sessionResult.SessionId,
                    sessionResult.TicketId,
                    sessionResult.TableId,
                    sessionResult.TableLabel);
                NavigationManager.NavigateTo("/menu");
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = L["OpenSessionFailed", ex.Message];
        }
        finally
        {
            IsOpeningSession = false;
        }
    }

    private async Task StartCameraAsync()
    {
        ErrorMessage = null;
        CameraMessage = null;
        ScannerModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "/js/qrScanner.js?v=20260427-1");
        DotNetRef ??= DotNetObjectReference.Create(this);

        var supported = await ScannerModule.InvokeAsync<bool>("isQrScannerSupported");
        if (!supported)
        {
            CameraMessage = L["CameraScanUnsupported"];
            return;
        }

        var started = await ScannerModule.InvokeAsync<bool>("startQrScanner", VideoElement, DotNetRef);
        CameraMessage = started ? L["CameraScanReady"] : L["CameraScanUnsupported"];
    }

    private async Task StopCameraAsync()
    {
        if (ScannerModule is null)
        {
            return;
        }

        await ScannerModule.InvokeVoidAsync("stopQrScanner");
        CameraMessage = L["CameraScanStopped"];
    }

    public async ValueTask DisposeAsync()
    {
        if (ScannerModule is not null)
        {
            try
            {
                await ScannerModule.InvokeVoidAsync("stopQrScanner");
                await ScannerModule.DisposeAsync();
            }
            catch
            {
            }
        }

        DotNetRef?.Dispose();
    }

    private record OpenSessionResult(Guid SessionId, Guid TicketId, Guid TableId, string TableLabel);
}
