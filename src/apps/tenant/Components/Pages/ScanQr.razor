@page "/scan-qr"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IStringLocalizer<TenantText> L
@inject CustomerSessionBrowserStore CustomerSessionStore

<PageTitle>@L["ScanQrTitle"]</PageTitle>

<section class="page-hero">
    <div>
        <p class="eyebrow">@L["NavScanQr"]</p>
        <h1>@L["ScanQrTitle"]</h1>
        <p class="hero-copy">@L["ScanQrHero"]</p>
    </div>
</section>

<section class="panel auth-panel">
    <div class="qr-input">
        <label>@L["EnterQrToken"]</label>
        <input type="text" @bind="QrToken" placeholder="QR Token" />
        <div class="form-actions">
            <button class="btn btn-primary" @onclick="OpenSession">@L["OpenSession"]</button>
            <button class="btn btn-secondary" @onclick="ResetScan">@L["ScanAgain"]</button>
        </div>
    </div>
</section>

@if (ErrorMessage is not null)
{
    <div class="alert alert-danger">@ErrorMessage</div>
}

@code {
    private string QrToken = string.Empty;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        var existingTicketId = (await CustomerSessionStore.GetSnapshotAsync()).TicketId;
        if (!string.IsNullOrEmpty(existingTicketId))
        {
            NavigationManager.NavigateTo("/menu");
        }
    }

    private void ResetScan()
    {
        QrToken = string.Empty;
        ErrorMessage = null;
    }

    private async Task OpenSession()
    {
        if (string.IsNullOrWhiteSpace(QrToken))
        {
            ErrorMessage = L["QrRequired"];
            return;
        }

        try
        {
            var result = await Http.PostAsJsonAsync("/api/public/session/open", new { QrTokenValue = QrToken });
            result.EnsureSuccessStatusCode();

            var sessionResult = await result.Content.ReadFromJsonAsync<OpenSessionResult>();
            if (sessionResult is not null)
            {
                await CustomerSessionStore.SetSnapshotAsync(
                    sessionResult.SessionId,
                    sessionResult.TicketId,
                    sessionResult.TableId,
                    sessionResult.TableLabel);
                NavigationManager.NavigateTo("/menu");
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = L["OpenSessionFailed", ex.Message];
        }
    }

    private record OpenSessionResult(Guid SessionId, Guid TicketId, Guid TableId, string TableLabel);
}
