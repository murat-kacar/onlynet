@page "/order/{orderId:guid}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Policy = "Tenant:Read")]
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IStringLocalizer<TenantText> L

<PageTitle>@L["OrderTitle"]</PageTitle>

<section class="page-hero">
    <div>
        <p class="eyebrow">@L["OrderTitle"]</p>
        <h1>@L["OrderTitle"] #@OrderId.ToString()[..8]</h1>
        <p class="hero-copy">@L["OrderHero"]</p>
    </div>
</section>

@if (OrderDetail is null)
{
    <section class="empty-state">
        <h3>@L["LoadingOrder"]</h3>
        <p>@L["LoadingOrderCopy"]</p>
    </section>
}
else
{
    <section class="detail-layout">
        <article class="panel detail-panel">
            <div class="kv-grid">
                <div class="kv-item">
                    <span class="kv-label">Table</span>
                    <span class="kv-value">@OrderDetail.TableLabel</span>
                </div>
                <div class="kv-item">
                    <span class="kv-label">@L["TableTotal"]</span>
                    <span class="kv-value">@OrderDetail.TotalAmount.ToString("C")</span>
                </div>
                <div class="kv-item form-span-2">
                    <span class="kv-label">@L["OrderStatus"]</span>
                    <span class="kv-value">@OrderDetail.Status</span>
                </div>
            </div>
        </article>
    </section>

    <section class="panel">
        <table class="table">
            <thead>
                <tr>
                    <th>@L["TableItem"]</th>
                    <th>@L["TableQuantity"]</th>
                    <th>@L["TablePrice"]</th>
                    <th>@L["OrderStatus"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in OrderDetail.Items)
                {
                    <tr>
                        <td>@item.ItemName</td>
                        <td>@item.Quantity</td>
                        <td>@item.UnitPrice.ToString("C")</td>
                        <td>@item.Status</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="form-actions">
            <button class="btn btn-secondary" @onclick="NavigateToMenu">@L["BackToMenu"]</button>
        </div>
    </section>
}

@code {
    [Parameter]
    public Guid OrderId { get; set; }

    private OrderDetailDto? OrderDetail;

    protected override async Task OnInitializedAsync()
    {
        OrderDetail = await Http.GetFromJsonAsync<OrderDetailDto>($"/api/orders/{OrderId}");
    }

    private void NavigateToMenu()
    {
        NavigationManager.NavigateTo("/menu");
    }

    private record OrderDetailDto(Guid OrderId, string TableLabel, decimal TotalAmount, string Status, IReadOnlyList<OrderItemDto> Items);
    private record OrderItemDto(Guid Id, string ItemName, int Quantity, decimal UnitPrice, string Status);
}
