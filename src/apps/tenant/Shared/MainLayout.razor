@inherits LayoutComponentBase
@namespace TabFlow.Tenant.Shared
@inject IStringLocalizer<TenantText> L
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject TenantUserPreferenceService PreferenceService
<div class="tenant-shell @(SidebarCollapsed ? "sidebar-collapsed" : null) @(InspectorCollapsed ? "inspector-collapsed" : null)" data-ui-density="@ShellDensity">
    <aside class="tenant-sidebar shell-sidebar">
        <div class="brand-block">
            <p class="eyebrow">@L["BrandEyebrow"]</p>
            <div class="brand-lockup">
                <span class="brand-mark" aria-hidden="true">
                    <span></span>
                    <span></span>
                </span>
                <h1>IoTable</h1>
            </div>
            <p class="brand-copy">@L["BrandCopy"]</p>
        </div>

        <nav class="tenant-nav" aria-label="Tenant">
            @if (IsAuthenticated)
            {
                <NavLink href="/tables" class="nav-link">@L["NavTables"]</NavLink>
                <NavLink href="/kitchen" class="nav-link">@L["NavKitchen"]</NavLink>
                <NavLink href="/settings" class="nav-link">@L["NavSettings"]</NavLink>
            }
            else
            {
                <NavLink href="/menu" class="nav-link">@L["NavMenu"]</NavLink>
                <NavLink href="/cart" class="nav-link">@L["NavCart"]</NavLink>
                <NavLink href="/scan-qr" class="nav-link">@L["NavScanQr"]</NavLink>
            }
        </nav>

        <div class="sidebar-footnote">
            <p>@L["ShellFootnote"]</p>
        </div>
    </aside>

    <div class="tenant-main shell-stage">
        <header class="tenant-header shell-topbar">
            <div class="topbar-start">
                <button type="button" class="chrome-toggle" @onclick="ToggleSidebar" aria-label="@L[SidebarCollapsed ? "ExpandNavigation" : "CollapseNavigation"]">
                    @(SidebarCollapsed ? ">" : "<")
                </button>
                <div class="shell-slot shell-slot-title">
                    <SectionOutlet SectionName="tenant-header" />
                </div>
                <div class="shell-slot-fallback">
                    <p class="eyebrow">@L["ShellEyebrow"]</p>
                    <h2>@L["ShellTitle"]</h2>
                </div>
            </div>
            <div class="topbar-end">
                <div class="shell-slot shell-slot-actions">
                    <SectionOutlet SectionName="tenant-header-actions" />
                </div>
                <div class="header-meta">
                    <span class="status-pill neutral">@(IsAuthenticated ? L["SignedInAs"] : L["AnonymousGuest"])</span>
                    <span class="header-identity">@DisplayIdentity</span>
                </div>
                <button type="button" class="chrome-toggle" @onclick="ToggleInspector" aria-label="@L[InspectorCollapsed ? "ShowContextPanel" : "HideContextPanel"]">
                    @(InspectorCollapsed ? "<" : ">")
                </button>
            </div>
        </header>

        <div class="shell-body">
            <main class="tenant-content shell-content">
                @Body
            </main>
            <aside class="shell-inspector">
                <div class="shell-inspector-header">
                    <p class="eyebrow">@L["ContextPanel"]</p>
                </div>
                <div class="shell-inspector-content">
                    <SectionOutlet SectionName="tenant-inspector" />
                </div>
            </aside>
        </div>
    </div>
</div>

@code {
    private bool IsAuthenticated { get; set; }
    private string DisplayIdentity { get; set; } = "IoTable";
    private string ShellDensity { get; set; } = TenantUserPreferenceService.DefaultDensity;
    private bool SidebarCollapsed { get; set; }
    private bool InspectorCollapsed { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            IsAuthenticated = authState.User.Identity?.IsAuthenticated == true;
            DisplayIdentity = authState.User.Identity?.Name ?? "IoTable";

            if (IsAuthenticated)
            {
                var preference = await PreferenceService.GetForPrincipalAsync(authState.User);
                ShellDensity = preference.Density;
            }
        }
        catch
        {
            ShellDensity = TenantUserPreferenceService.DefaultDensity;
        }
    }

    private void ToggleSidebar() => SidebarCollapsed = !SidebarCollapsed;
    private void ToggleInspector() => InspectorCollapsed = !InspectorCollapsed;
}
