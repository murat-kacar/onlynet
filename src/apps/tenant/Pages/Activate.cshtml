@page "/activate"
@model ActivateModel
@{ ViewData["Title"] = "Activate Account"; }

<section class="auth-shell">
    <div class="auth-hero">
        <p class="eyebrow">Tenant Access</p>
        <h1>Activate Admin Account</h1>
        <p class="hero-copy">Finish the one-time activation to set your password and continue to security setup.</p>
    </div>

    <div class="auth-panel">
        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="alert alert-danger">@Model.StatusMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Email))
        {
            <div class="kv-grid">
                <div class="kv-item form-span-2">
                    <span class="kv-label">Admin Account</span>
                    <span class="kv-value">@Model.Email</span>
                </div>
            </div>
        }

        <form method="post">
            <input type="hidden" asp-for="Token" />

            <div class="form-grid">
                <div class="form-group form-span-2">
                    <label asp-for="Password">Password</label>
                    <input asp-for="Password" type="password" class="form-control" autocomplete="new-password" />
                </div>
                <div class="form-group form-span-2">
                    <label asp-for="ConfirmPassword">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                </div>
            </div>

            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Activate Account</button>
                <a class="btn btn-secondary" href="/login">Back to Login</a>
            </div>
        </form>
    </div>
</section>
