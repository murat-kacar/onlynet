@page "/audit"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Platform:Read")]
@inject IStringLocalizer<PlatformText> L
@inject IPlatformAuditReadService PlatformAuditReadService

<PageTitle>@L["AuditPageTitle"]</PageTitle>

<SectionContent SectionName="platform-header">
    <div>
        <p class="eyebrow">@L["ComplianceEyebrow"]</p>
        <h2>@L["AuditPageTitle"]</h2>
        <p class="hero-copy">@L["AuditHero"]</p>
    </div>
</SectionContent>

<SectionContent SectionName="platform-inspector">
    @if (SelectedEntry is null)
    {
        <div class="console-context">
            <section class="context-card">
                <h4>@L["NoEventSelected"]</h4>
                <p class="detail-copy">@L["NoEventSelectedCopy"]</p>
            </section>
        </div>
    }
    else
    {
        <div class="console-context">
            <section class="context-card">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">@L["Selection"]</p>
                        <h3>@SelectedEntry.Action</h3>
                    </div>
                    <span class="@ActionClass(SelectedEntry.Action)">@EntryTone(SelectedEntry.Action)</span>
                </div>

                <div class="kv-grid">
                    <div class="kv-item">
                        <span class="kv-label">@L["TableWhen"]</span>
                        <span class="kv-value">@FormatDate(SelectedEntry.CreatedAt)</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-label">@L["TableActor"]</span>
                        <span class="kv-value">@SelectedEntry.ActorEmail</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-label">@L["ResourceType"]</span>
                        <span class="kv-value">@SelectedEntry.ResourceType</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-label">@L["TableIp"]</span>
                        <span class="kv-value">@(SelectedEntry.Ip ?? "-")</span>
                    </div>
                    <div class="kv-item form-span-2">
                        <span class="kv-label">@L["ResourceId"]</span>
                        <span class="kv-value">@SelectedEntry.ResourceId</span>
                    </div>
                </div>
            </section>

            <section class="context-card">
                <div class="kv-grid">
                    <div class="kv-item">
                        <span class="kv-label">@L["Actors"]</span>
                        <span class="kv-value">@SelectedActorEntryCount</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-label">@L["TableResource"]</span>
                        <span class="kv-value">@SelectedResourceEntryCount</span>
                    </div>
                    <div class="kv-item form-span-2">
                        <span class="kv-label">@L["Actions"]</span>
                        <span class="kv-value">@EntryTone(SelectedEntry.Action)</span>
                    </div>
                </div>
            </section>

            <section class="context-card">
                <p class="detail-title">@L["OperatorNotes"]</p>
                <p class="detail-copy">@EntryCopy(SelectedEntry)</p>
            </section>
        </div>
    }
</SectionContent>

@if (LoadError is not null)
{
    <div class="alert alert-danger">@LoadError</div>
}
else
{
    <section class="dashboard-overview-grid">
        <article class="overview-surface overview-surface-primary">
            <div class="surface-heading">
                <div>
                    <p class="eyebrow">@L["ComplianceEyebrow"]</p>
                    <h3>@L["Entries"]</h3>
                </div>
                <span class="status-pill neutral">@FilterSummary</span>
            </div>
            <p class="surface-copy">@L["EntriesVisibleCopy"]</p>
            <div class="overview-stat-row">
                <div>
                    <span class="metric-label">@L["Entries"]</span>
                    <strong class="metric-value">@FilteredEntries.Count</strong>
                </div>
                <div>
                    <span class="metric-label">@L["Actors"]</span>
                    <strong class="metric-value">@DistinctActors</strong>
                </div>
            </div>
        </article>

        <article class="overview-surface">
            <div class="surface-heading">
                <div>
                    <p class="eyebrow">@L["Actions"]</p>
                    <h3>@DistinctActions</h3>
                </div>
            </div>
            <p class="surface-copy">@L["ActionsCopy"]</p>
            <div class="overview-inline-metrics">
                <span>@L["Auth"]: @AuthEntriesCount</span>
                <span>@L["TableTenant"]: @TenantEntriesCount</span>
            </div>
        </article>

        <article class="overview-surface">
            <div class="surface-heading">
                <div>
                    <p class="eyebrow">@L["Selection"]</p>
                    <h3>@(SelectedEntry?.Action ?? L["NoEventSelected"])</h3>
                </div>
            </div>
            <p class="surface-copy">@(SelectedEntry is null ? L["NoEventSelectedCopy"] : FormatDate(SelectedEntry.CreatedAt))</p>
            <div class="overview-inline-metrics">
                <span>@L["TableActor"]: @(SelectedEntry?.ActorEmail ?? "-")</span>
                <span>@L["ResourceType"]: @(SelectedEntry?.ResourceType ?? "-")</span>
            </div>
        </article>
    </section>

    <section class="panel">
        <div class="registry-toolbar">
            <div class="search-field">
                <label for="audit-search">@L["SearchAudit"]</label>
                <input id="audit-search" value="@SearchTerm" @oninput="OnSearchChanged" class="form-control" placeholder="@L["SearchAuditPlaceholder"]" />
            </div>

            <div class="filter-group">
                <button type="button" class="@FilterButtonClass("all")" @onclick='() => SetActionFilter("all")'>@L["FilterAll"]</button>
                <button type="button" class="@FilterButtonClass("auth")" @onclick='() => SetActionFilter("auth")'>@L["Auth"]</button>
                <button type="button" class="@FilterButtonClass("tenant")" @onclick='() => SetActionFilter("tenant")'>@L["TableTenant"]</button>
            </div>
        </div>

        @if (FilteredEntries.Count == 0)
        {
            <div class="empty-state compact-empty">
                <h4>@L["NoAuditEntriesYet"]</h4>
                <p>@L["NoAuditEntriesYetCopy"]</p>
                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="ClearFilters">@L["ClearFilters"]</button>
                </div>
            </div>
        }
        else
        {
            <div class="surface-stack">
                <div class="toolbar-meta">
                    <p>@FilterSummary</p>
                    <p>@PagingSummary</p>
                </div>

                <div class="table-shell">
                    <table class="table audit-table">
                        <thead>
                            <tr>
                                <th>@L["TableWhen"]</th>
                                <th>@L["TableActor"]</th>
                                <th>@L["TableAction"]</th>
                                <th>@L["TableResource"]</th>
                                <th>@L["TableIp"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in VisibleEntries)
                            {
                                var isSelected = entry.Id == SelectedEntry?.Id;

                                <tr class="@RowClass(isSelected)" @onclick="() => SelectEntry(entry.Id)">
                                    <td>@FormatDate(entry.CreatedAt)</td>
                                    <td>@entry.ActorEmail</td>
                                    <td><span class="@ActionClass(entry.Action)">@entry.Action</span></td>
                                    <td>
                                        <div class="tenant-cell">
                                            <p class="list-title">@entry.ResourceType</p>
                                            <p class="list-subtitle">@entry.ResourceId</p>
                                        </div>
                                    </td>
                                    <td>@(entry.Ip ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="table-footer">
                    <p>@PagingSummary</p>
                    <div class="pagination">
                        <button type="button" class="btn btn-sm btn-secondary" @onclick="PreviousPage" disabled="@(CurrentPage == 1)">@L["Previous"]</button>
                        <span>@L["PageOf", CurrentPage, TotalPages]</span>
                        <button type="button" class="btn btn-sm btn-secondary" @onclick="NextPage" disabled="@(CurrentPage >= TotalPages)">@L["Next"]</button>
                    </div>
                </div>
            </div>
        }
    </section>
}

@code {
    private const int PageSize = 10;
    private List<PlatformAuditEntryDto> AuditEntries = [];
    private Guid? SelectedEntryId;
    private string SearchTerm { get; set; } = string.Empty;
    private string ActionFilter { get; set; } = "all";
    private int CurrentPage { get; set; } = 1;
    private string? LoadError;
    private int DistinctActors => FilteredEntries.Select(entry => entry.ActorEmail).Distinct(StringComparer.OrdinalIgnoreCase).Count();
    private int DistinctActions => FilteredEntries.Select(entry => entry.Action).Distinct(StringComparer.OrdinalIgnoreCase).Count();
    private int AuthEntriesCount => FilteredEntries.Count(entry => entry.Action.StartsWith("auth.", StringComparison.OrdinalIgnoreCase));
    private int TenantEntriesCount => FilteredEntries.Count(entry => entry.Action.StartsWith("tenant.", StringComparison.OrdinalIgnoreCase));
    private int SelectedActorEntryCount =>
        SelectedEntry is null
            ? 0
            : AuditEntries.Count(entry => string.Equals(entry.ActorEmail, SelectedEntry.ActorEmail, StringComparison.OrdinalIgnoreCase));
    private int SelectedResourceEntryCount =>
        SelectedEntry is null
            ? 0
            : AuditEntries.Count(entry =>
                string.Equals(entry.ResourceType, SelectedEntry.ResourceType, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(entry.ResourceId, SelectedEntry.ResourceId, StringComparison.OrdinalIgnoreCase));
    private IReadOnlyList<PlatformAuditEntryDto> FilteredEntries =>
        AuditEntries
            .Where(MatchesSearch)
            .Where(MatchesActionFilter)
            .ToList();

    private IReadOnlyList<PlatformAuditEntryDto> VisibleEntries =>
        FilteredEntries
            .Skip((CurrentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();

    private PlatformAuditEntryDto? SelectedEntry =>
        VisibleEntries.FirstOrDefault(entry => entry.Id == SelectedEntryId) ?? VisibleEntries.FirstOrDefault();

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredEntries.Count / (double)PageSize));

    private string FilterSummary =>
        L["MatchingAuditSummary", FilteredEntries.Count, AuditEntries.Count];

    private string PagingSummary
    {
        get
        {
            if (FilteredEntries.Count == 0)
            {
                return L["ShowingZeroResults"];
            }

            var start = ((CurrentPage - 1) * PageSize) + 1;
            var end = Math.Min(CurrentPage * PageSize, FilteredEntries.Count);
            return L["ShowingResults", start, end, FilteredEntries.Count];
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            AuditEntries = (await PlatformAuditReadService.GetEntriesAsync()).ToList();
            EnsureSelection();
        }
        catch (Exception ex)
        {
            LoadError = L["AuditLoadError", ex.Message];
        }
    }

    private bool MatchesSearch(PlatformAuditEntryDto entry)
    {
        if (string.IsNullOrWhiteSpace(SearchTerm))
        {
            return true;
        }

        return entry.ActorEmail.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
               entry.Action.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
               entry.ResourceType.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
               entry.ResourceId.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesActionFilter(PlatformAuditEntryDto entry)
    {
        return ActionFilter switch
        {
            "auth" => entry.Action.StartsWith("auth.", StringComparison.OrdinalIgnoreCase),
            "tenant" => entry.Action.StartsWith("tenant.", StringComparison.OrdinalIgnoreCase),
            _ => true,
        };
    }

    private void SetActionFilter(string filter)
    {
        ActionFilter = filter;
        CurrentPage = 1;
        EnsureSelection();
    }

    private void OnSearchChanged(ChangeEventArgs args)
    {
        SearchTerm = args.Value?.ToString() ?? string.Empty;
        CurrentPage = 1;
        EnsureSelection();
    }

    private void ClearFilters()
    {
        SearchTerm = string.Empty;
        ActionFilter = "all";
        CurrentPage = 1;
        EnsureSelection();
    }

    private void SelectEntry(Guid entryId)
    {
        SelectedEntryId = entryId;
    }

    private void PreviousPage()
    {
        if (CurrentPage <= 1)
        {
            return;
        }

        CurrentPage--;
        EnsureSelection();
    }

    private void NextPage()
    {
        if (CurrentPage >= TotalPages)
        {
            return;
        }

        CurrentPage++;
        EnsureSelection();
    }

    private void EnsureSelection()
    {
        if (CurrentPage > TotalPages)
        {
            CurrentPage = TotalPages;
        }

        var selected = VisibleEntries.FirstOrDefault(entry => entry.Id == SelectedEntryId) ?? VisibleEntries.FirstOrDefault();
        SelectedEntryId = selected?.Id;
    }

    private string FilterButtonClass(string filter) =>
        ActionFilter == filter ? "filter-chip active" : "filter-chip";

    private static string RowClass(bool isSelected) =>
        isSelected ? "data-row selected" : "data-row";

    private static string ActionClass(string action)
    {
        if (action.StartsWith("auth.", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill warning";
        }

        if (action.StartsWith("tenant.", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill success";
        }

        return "status-pill neutral";
    }

    private string EntryTone(string action)
    {
        if (action.StartsWith("auth.", StringComparison.OrdinalIgnoreCase))
        {
            return L["AuthTone"];
        }

        if (action.StartsWith("tenant.", StringComparison.OrdinalIgnoreCase))
        {
            return L["TenantTone"];
        }

        return L["PlatformTone"];
    }

    private string EntryCopy(PlatformAuditEntryDto entry)
    {
        if (entry.Action.StartsWith("auth.", StringComparison.OrdinalIgnoreCase))
        {
            return L["AuthEntryCopy"];
        }

        if (entry.Action.StartsWith("tenant.", StringComparison.OrdinalIgnoreCase))
        {
            return L["TenantEntryCopy"];
        }

        return L["PlatformEntryCopy"];
    }

    private static string FormatDate(DateTimeOffset value) =>
        value.ToString("yyyy-MM-dd HH:mm");
}
