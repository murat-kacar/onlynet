@page "/tenants"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Platform:Read")]
@inject DialogService DialogService
@inject NavigationManager NavigationManager
@inject ITenantRegistryService TenantRegistryService

<PageTitle>Tenants</PageTitle>

<RadzenComponents />

<section class="page-hero">
    <div>
        <p class="eyebrow">Registry</p>
        <h1>Tenants</h1>
        <p class="hero-copy">Search the tenant registry, check rollout status, and jump straight into a regional configuration record.</p>
    </div>
    <AuthorizeView Policy="Platform:Write">
        <div class="hero-actions">
            <button type="button" class="btn btn-primary" @onclick="OpenCreateTenantAsync">Create Tenant</button>
        </div>
    </AuthorizeView>
</section>

@if (LoadError is not null)
{
    <div class="alert alert-danger">@LoadError</div>
}
else if (TenantList == null)
{
    <section class="empty-state">
        <h3>Loading tenant registry</h3>
        <p>The current tenant list is being fetched from the platform API.</p>
    </section>
}
else
{
    <section class="stats-grid compact-stats">
        <article class="metric-card">
            <p class="metric-label">Visible Tenants</p>
            <p class="metric-value">@FilteredTenants.Count</p>
            <p class="metric-footnote">@VisibleTenants.Count shown on this page</p>
        </article>
        <article class="metric-card">
            <p class="metric-label">Active</p>
            <p class="metric-value">@TenantList.Count(t => IsStatus(t.Status, "active"))</p>
            <p class="metric-footnote">Healthy runtime records</p>
        </article>
        <article class="metric-card">
            <p class="metric-label">Provisioning</p>
            <p class="metric-value">@TenantList.Count(t => !IsStatus(t.Status, "active"))</p>
            <p class="metric-footnote">Need rollout follow-up</p>
        </article>
    </section>

    <section class="panel">
        <div class="registry-toolbar">
            <div class="search-field">
                <label for="tenant-search">Search tenants</label>
                <input id="tenant-search" value="@SearchTerm" @oninput="OnSearchChanged" class="form-control" placeholder="Code, domain, display name" />
            </div>

            <div class="filter-group">
                <button type="button" class="@FilterButtonClass("all")" @onclick='() => SetStatusFilter("all")'>All</button>
                <button type="button" class="@FilterButtonClass("active")" @onclick='() => SetStatusFilter("active")'>Active</button>
                <button type="button" class="@FilterButtonClass("other")" @onclick='() => SetStatusFilter("other")'>Needs attention</button>
            </div>
        </div>

        @if (FilteredTenants.Count == 0)
        {
            <div class="empty-state compact-empty">
                <h4>No tenants match this view</h4>
                <p>Try clearing the search term or switching the status filter.</p>
                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="ClearFilters">Clear Filters</button>
                    <AuthorizeView Policy="Platform:Write">
                        <button type="button" class="btn btn-primary" @onclick="OpenCreateTenantAsync">Create Tenant</button>
                    </AuthorizeView>
                </div>
            </div>
        }
        else
        {
            <div class="inspector-layout">
                <div class="surface-stack">
                    <div class="toolbar-meta">
                        <p>@FilterSummary</p>
                        <p>@PagingSummary</p>
                    </div>

                    <div class="table-shell">
                        <table class="table tenants-table">
                            <thead>
                                <tr>
                                    <th>Tenant</th>
                                    <th>Status</th>
                                    <th>Locale</th>
                                    <th>Domain</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tenant in VisibleTenants)
                                {
                                    var isSelected = tenant.Id == SelectedTenant?.Id;

                                    <tr class="@RowClass(isSelected)" @onclick="() => SelectTenant(tenant.Id)">
                                        <td>
                                            <div class="tenant-cell">
                                                <p class="list-title">@tenant.DisplayName</p>
                                                <p class="list-subtitle">@tenant.Code</p>
                                            </div>
                                        </td>
                                        <td><span class="@StatusClass(tenant.Status)">@tenant.Status</span></td>
                                        <td>@tenant.LanguageCode · @tenant.CurrencyCode · @tenant.TimeZone</td>
                                        <td>@tenant.PrimaryDomain</td>
                                        <td class="actions-cell">
                                            <button type="button" class="btn btn-sm btn-secondary" @onclick:stopPropagation="true" @onclick="() => SelectTenant(tenant.Id)">Inspect</button>
                                            <button type="button" class="btn btn-sm btn-primary" @onclick:stopPropagation="true" @onclick="() => NavigateToDetail(tenant.Id)">Open</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="table-footer">
                        <p>@PagingSummary</p>
                        <div class="pagination">
                            <button type="button" class="btn btn-sm btn-secondary" @onclick="PreviousPage" disabled="@(CurrentPage == 1)">Previous</button>
                            <span>Page @CurrentPage of @TotalPages</span>
                            <button type="button" class="btn btn-sm btn-secondary" @onclick="NextPage" disabled="@(CurrentPage >= TotalPages)">Next</button>
                        </div>
                    </div>
                </div>

                <aside class="detail-card">
                    @if (SelectedTenant is null)
                    {
                        <div class="empty-state compact-empty">
                            <h4>No tenant selected</h4>
                            <p>Select a row to review its registry snapshot.</p>
                        </div>
                    }
                    else
                    {
                        <div class="panel-header">
                            <div>
                                <p class="eyebrow">Selection</p>
                                <h3>@SelectedTenant.DisplayName</h3>
                            </div>
                            <span class="@StatusClass(SelectedTenant.Status)">@SelectedTenant.Status</span>
                        </div>

                        <div class="detail-stack">
                            <div class="kv-grid">
                                <div class="kv-item">
                                    <span class="kv-label">Tenant Code</span>
                                    <span class="kv-value">@SelectedTenant.Code</span>
                                </div>
                                <div class="kv-item">
                                    <span class="kv-label">Primary Domain</span>
                                    <span class="kv-value">@SelectedTenant.PrimaryDomain</span>
                                </div>
                                <div class="kv-item">
                                    <span class="kv-label">Language</span>
                                    <span class="kv-value">@SelectedTenant.LanguageCode</span>
                                </div>
                                <div class="kv-item">
                                    <span class="kv-label">Currency</span>
                                    <span class="kv-value">@SelectedTenant.CurrencyCode</span>
                                </div>
                                <div class="kv-item form-span-2">
                                    <span class="kv-label">Time Zone</span>
                                    <span class="kv-value">@SelectedTenant.TimeZone</span>
                                </div>
                            </div>

                            <section class="detail-section">
                                <p class="detail-title">Operator Notes</p>
                                <p class="detail-copy">@TenantStatusCopy(SelectedTenant)</p>
                            </section>

                            <div class="form-actions">
                                <button type="button" class="btn btn-primary" @onclick="() => NavigateToDetail(SelectedTenant.Id)">Open Full Record</button>
                                <AuthorizeView Policy="Platform:Write">
                                    <button type="button" class="btn btn-secondary" @onclick="() => OpenEditTenantAsync(SelectedTenant.Id)">Edit Settings</button>
                                    <button type="button" class="btn btn-secondary" @onclick="OpenCreateTenantAsync">Create Another</button>
                                </AuthorizeView>
                            </div>
                        </div>
                    }
                </aside>
            </div>
        }
    </section>
}

@code {
    private const int PageSize = 8;
    private List<TenantDto>? TenantList;
    private Guid? SelectedTenantId;
    private string SearchTerm { get; set; } = string.Empty;
    private string StatusFilter { get; set; } = "all";
    private int CurrentPage { get; set; } = 1;
    private string? LoadError;

    private IReadOnlyList<TenantDto> FilteredTenants =>
        (TenantList ?? [])
            .Where(MatchesSearch)
            .Where(MatchesFilter)
            .OrderBy(t => t.DisplayName)
            .ToList();

    private IReadOnlyList<TenantDto> VisibleTenants =>
        FilteredTenants
            .Skip((CurrentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();

    private TenantDto? SelectedTenant =>
        VisibleTenants.FirstOrDefault(t => t.Id == SelectedTenantId) ?? VisibleTenants.FirstOrDefault();

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredTenants.Count / (double)PageSize));

    private string FilterSummary =>
        $"{FilteredTenants.Count} matching tenants from {TenantList?.Count ?? 0} registry records";

    private string PagingSummary
    {
        get
        {
            if (FilteredTenants.Count == 0)
            {
                return "Showing 0 results";
            }

            var start = ((CurrentPage - 1) * PageSize) + 1;
            var end = Math.Min(CurrentPage * PageSize, FilteredTenants.Count);
            return $"Showing {start}-{end} of {FilteredTenants.Count}";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await RefreshTenantListAsync();
            EnsureSelection();
        }
        catch (Exception ex)
        {
            LoadError = $"Tenant registry failed to load: {ex.Message}";
        }
    }

    private void NavigateToDetail(Guid id)
    {
        NavigationManager.NavigateTo($"/tenants/{id}");
    }

    private async Task OpenCreateTenantAsync()
    {
        var result = await DialogService.OpenSideAsync<TenantEditorPanel>(
            "Create Tenant",
            new Dictionary<string, object?>(),
            CreateDialogOptions());

        if (result is Guid createdTenantId && createdTenantId != Guid.Empty)
        {
            await RefreshTenantListAsync(createdTenantId);
        }
    }

    private async Task OpenEditTenantAsync(Guid tenantId)
    {
        var result = await DialogService.OpenSideAsync<TenantEditorPanel>(
            "Edit Tenant",
            new Dictionary<string, object?>
            {
                [nameof(TenantEditorPanel.TenantId)] = tenantId,
            },
            EditDialogOptions());

        if (result is Guid updatedTenantId && updatedTenantId != Guid.Empty)
        {
            await RefreshTenantListAsync(updatedTenantId);
        }
    }

    private bool MatchesSearch(TenantDto tenant)
    {
        if (string.IsNullOrWhiteSpace(SearchTerm))
        {
            return true;
        }

        return tenant.Code.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
               tenant.DisplayName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
               tenant.PrimaryDomain.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesFilter(TenantDto tenant)
    {
        return StatusFilter switch
        {
            "active" => IsStatus(tenant.Status, "active"),
            "other" => !IsStatus(tenant.Status, "active"),
            _ => true,
        };
    }

    private void SetStatusFilter(string filter)
    {
        StatusFilter = filter;
        CurrentPage = 1;
        EnsureSelection();
    }

    private void ClearFilters()
    {
        SearchTerm = string.Empty;
        StatusFilter = "all";
        CurrentPage = 1;
        EnsureSelection();
    }

    private void OnSearchChanged(ChangeEventArgs args)
    {
        SearchTerm = args.Value?.ToString() ?? string.Empty;
        CurrentPage = 1;
        EnsureSelection();
    }

    private void SelectTenant(Guid tenantId)
    {
        SelectedTenantId = tenantId;
    }

    private void PreviousPage()
    {
        if (CurrentPage <= 1)
        {
            return;
        }

        CurrentPage--;
        EnsureSelection();
    }

    private void NextPage()
    {
        if (CurrentPage >= TotalPages)
        {
            return;
        }

        CurrentPage++;
        EnsureSelection();
    }

    private void EnsureSelection()
    {
        if (CurrentPage > TotalPages)
        {
            CurrentPage = TotalPages;
        }

        var selected = VisibleTenants.FirstOrDefault(t => t.Id == SelectedTenantId) ?? VisibleTenants.FirstOrDefault();
        SelectedTenantId = selected?.Id;
    }

    private async Task RefreshTenantListAsync(Guid? selectedTenantId = null)
    {
        TenantList = (await TenantRegistryService.GetTenantsAsync()).ToList();

        if (selectedTenantId.HasValue)
        {
            SearchTerm = string.Empty;
            StatusFilter = "all";
            var selectedIndex = TenantList
                .OrderBy(t => t.DisplayName)
                .Select((tenant, index) => new { tenant.Id, index })
                .FirstOrDefault(item => item.Id == selectedTenantId.Value)
                ?.index;

            if (selectedIndex.HasValue)
            {
                CurrentPage = (selectedIndex.Value / PageSize) + 1;
                SelectedTenantId = selectedTenantId;
            }
        }

        EnsureSelection();
        await InvokeAsync(StateHasChanged);
    }

    private static SideDialogOptions CreateDialogOptions() => new()
    {
        Position = DialogPosition.Right,
        ShowMask = true,
        CloseDialogOnOverlayClick = false,
        Width = "560px",
        CssClass = "platform-side-dialog",
        WrapperCssClass = "platform-side-dialog-wrapper",
        ContentCssClass = "platform-side-dialog-content",
    };

    private static SideDialogOptions EditDialogOptions() => new()
    {
        Position = DialogPosition.Right,
        ShowMask = true,
        CloseDialogOnOverlayClick = false,
        Width = "520px",
        CssClass = "platform-side-dialog",
        WrapperCssClass = "platform-side-dialog-wrapper",
        ContentCssClass = "platform-side-dialog-content",
    };

    private string FilterButtonClass(string filter) =>
        StatusFilter == filter ? "filter-chip active" : "filter-chip";

    private static string RowClass(bool isSelected) =>
        isSelected ? "data-row selected" : "data-row";

    private static string TenantStatusCopy(TenantDto tenant) =>
        IsStatus(tenant.Status, "active")
            ? "This tenant is marked active and should be reachable through its assigned runtime surface."
            : "This tenant is not active yet and should be checked against provisioning progress or rollout blockers.";

    private static bool IsStatus(string? value, string expected) =>
        string.Equals(value, expected, StringComparison.OrdinalIgnoreCase);

    private static string StatusClass(string status)
    {
        if (string.Equals(status, "active", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "completed", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill success";
        }
        if (string.Equals(status, "failed", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill danger";
        }
        if (string.Equals(status, "claimed", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "running", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill warning";
        }
        return "status-pill neutral";
    }
}
