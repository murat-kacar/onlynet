@page "/tenants"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Platform:Read")]
@inject IStringLocalizer<PlatformText> L
@inject DialogService DialogService
@inject NavigationManager NavigationManager
@inject ITenantRegistryService TenantRegistryService

<PageTitle>@L["TenantsPageTitle"]</PageTitle>

<RadzenComponents />

<SectionContent SectionName="platform-header">
    <div>
        <p class="eyebrow">@L["RegistryEyebrow"]</p>
        <h2>@L["TenantsPageTitle"]</h2>
        <p class="hero-copy">@L["TenantsHero"]</p>
    </div>
</SectionContent>

<SectionContent SectionName="platform-header-actions">
    <AuthorizeView Policy="Platform:Write">
        <button type="button" class="btn btn-primary" @onclick="OpenCreateTenantAsync">@L["CreateTenant"]</button>
    </AuthorizeView>
</SectionContent>

<SectionContent SectionName="platform-inspector">
    @if (SelectedTenant is null)
    {
        <div class="console-context">
            <section class="context-card">
                <h4>@L["NoTenantSelected"]</h4>
                <p class="detail-copy">@L["NoTenantSelectedCopy"]</p>
            </section>
        </div>
    }
    else
    {
        <div class="console-context">
            <section class="context-card">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">@L["Selection"]</p>
                        <h3>@SelectedTenant.DisplayName</h3>
                    </div>
                    <span class="@StatusClass(SelectedTenant.Status)">@LocalizedStatus(SelectedTenant.Status)</span>
                </div>

                <div class="kv-grid">
                    <div class="kv-item">
                        <span class="kv-label">@L["TenantCode"]</span>
                        <span class="kv-value">@SelectedTenant.Code</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-label">@L["PrimaryDomain"]</span>
                        <span class="kv-value">@SelectedTenant.PrimaryDomain</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-label">@L["Language"]</span>
                        <span class="kv-value">@SelectedTenant.LanguageCode</span>
                    </div>
                    <div class="kv-item">
                        <span class="kv-label">@L["Currency"]</span>
                        <span class="kv-value">@SelectedTenant.CurrencyCode</span>
                    </div>
                    <div class="kv-item form-span-2">
                        <span class="kv-label">@L["TimeZone"]</span>
                        <span class="kv-value">@SelectedTenant.TimeZone</span>
                    </div>
                </div>
            </section>

            <section class="context-card">
                <p class="detail-title">@L["OperatorNotes"]</p>
                <p class="detail-copy">@TenantStatusCopy(SelectedTenant)</p>
                <div class="form-actions">
                    <button type="button" class="btn btn-primary" @onclick="() => NavigateToDetail(SelectedTenant.Id)">@L["OpenFullRecord"]</button>
                    <AuthorizeView Policy="Platform:Write">
                        <button type="button" class="btn btn-secondary" @onclick="() => OpenEditTenantAsync(SelectedTenant.Id)">@L["EditSettings"]</button>
                    </AuthorizeView>
                </div>
            </section>
        </div>
    }
</SectionContent>

@if (LoadError is not null)
{
    <div class="alert alert-danger">@LoadError</div>
}
else if (TenantList is null)
{
    <section class="empty-state">
        <h3>@L["LoadingTenantRegistry"]</h3>
        <p>@L["LoadingTenantRegistryCopy"]</p>
    </section>
}
else
{
    <section class="dashboard-overview-grid">
        <article class="overview-surface overview-surface-primary">
            <div class="surface-heading">
                <div>
                    <p class="eyebrow">@L["RegistryEyebrow"]</p>
                    <h3>@L["MetricVisibleTenants"]</h3>
                </div>
                <span class="status-pill neutral">@FilteredTenants.Count</span>
            </div>

            <div class="overview-stat-row">
                <div class="overview-stat-block">
                    <p class="overview-stat-value">@TenantList.Count</p>
                    <p class="overview-stat-label">@L["MetricTenants"]</p>
                </div>
                <div class="overview-stat-block">
                    <p class="overview-stat-value">@ActiveTenants</p>
                    <p class="overview-stat-label">@L["MetricActive"]</p>
                </div>
                <div class="overview-stat-block">
                    <p class="overview-stat-value">@ProvisioningTenants</p>
                    <p class="overview-stat-label">@L["MetricProvisioning"]</p>
                </div>
            </div>

            <p class="surface-copy">@L["MatchingTenantsSummary", FilteredTenants.Count, TenantList.Count]</p>
        </article>

        <article class="overview-surface">
            <div class="surface-heading">
                <div>
                    <p class="eyebrow">@L["AttentionEyebrow"]</p>
                    <h3>@L["NeedsAttention"]</h3>
                </div>
                <span class="status-pill warning">@ProvisioningTenants</span>
            </div>

            <div class="overview-inline-metrics">
                <div>
                    <p class="overview-inline-value">@ProvisioningTenants</p>
                    <p class="overview-inline-label">@L["MetricProvisioning"]</p>
                </div>
                <div>
                    <p class="overview-inline-value">@ActiveTenants</p>
                    <p class="overview-inline-label">@L["MetricActive"]</p>
                </div>
            </div>

            <p class="surface-copy">@L["ProvisioningTenantsCopy"]</p>
        </article>

        <article class="overview-surface">
            <div class="surface-heading">
                <div>
                    <p class="eyebrow">@L["MetricNewestTenant"]</p>
                    <h3>@NewestTenantLabel</h3>
                </div>
                <span class="status-pill neutral">@LatestTenantStatus</span>
            </div>

            <p class="surface-copy">@LatestTenantDomain</p>
        </article>
    </section>

    <section class="panel">
        <div class="registry-toolbar">
            <div class="search-field">
                <label for="tenant-search">@L["SearchTenants"]</label>
                <input id="tenant-search" value="@SearchTerm" @oninput="OnSearchChanged" class="form-control" placeholder="@L["SearchTenantsPlaceholder"]" />
            </div>

            <div class="filter-group">
                <button type="button" class="@FilterButtonClass("all")" @onclick='() => SetStatusFilter("all")'>@L["FilterAll"]</button>
                <button type="button" class="@FilterButtonClass("active")" @onclick='() => SetStatusFilter("active")'>@L["MetricActive"]</button>
                <button type="button" class="@FilterButtonClass("other")" @onclick='() => SetStatusFilter("other")'>@L["NeedsAttention"]</button>
            </div>
        </div>

        @if (FilteredTenants.Count == 0)
        {
            <div class="empty-state compact-empty">
                <h4>@L["NoTenantsMatch"]</h4>
                <p>@L["NoTenantsMatchCopy"]</p>
                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="ClearFilters">@L["ClearFilters"]</button>
                    <AuthorizeView Policy="Platform:Write">
                        <button type="button" class="btn btn-primary" @onclick="OpenCreateTenantAsync">@L["CreateTenant"]</button>
                    </AuthorizeView>
                </div>
            </div>
        }
        else
        {
            <div class="surface-stack">
                <div class="toolbar-meta">
                    <p>@L["MatchingTenantsSummary", FilteredTenants.Count, TenantList.Count]</p>
                    <p>@PagingSummary</p>
                </div>

                <div class="table-shell">
                    <table class="table tenants-table">
                        <thead>
                            <tr>
                                <th>@L["TableTenant"]</th>
                                <th>@L["TableStatus"]</th>
                                <th>@L["TableLocale"]</th>
                                <th>@L["TableDomain"]</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tenant in VisibleTenants)
                            {
                                var isSelected = tenant.Id == SelectedTenant?.Id;
                                <tr class="@RowClass(isSelected)" @onclick="() => SelectTenant(tenant.Id)">
                                    <td>
                                        <div class="tenant-cell">
                                            <p class="list-title">@tenant.DisplayName</p>
                                            <p class="list-subtitle">@tenant.Code</p>
                                        </div>
                                    </td>
                                    <td><span class="@StatusClass(tenant.Status)">@LocalizedStatus(tenant.Status)</span></td>
                                    <td>@tenant.LanguageCode · @tenant.CurrencyCode · @tenant.TimeZone</td>
                                    <td>@tenant.PrimaryDomain</td>
                                    <td class="actions-cell">
                                        <button type="button" class="btn btn-sm btn-secondary" @onclick:stopPropagation="true" @onclick="() => SelectTenant(tenant.Id)">@L["Inspect"]</button>
                                        <button type="button" class="btn btn-sm btn-primary" @onclick:stopPropagation="true" @onclick="() => NavigateToDetail(tenant.Id)">@L["Open"]</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="table-footer">
                    <p>@PagingSummary</p>
                    <div class="pagination">
                        <button type="button" class="btn btn-sm btn-secondary" @onclick="PreviousPage" disabled="@(CurrentPage == 1)">@L["Previous"]</button>
                        <span>@L["PageOf", CurrentPage, TotalPages]</span>
                        <button type="button" class="btn btn-sm btn-secondary" @onclick="NextPage" disabled="@(CurrentPage >= TotalPages)">@L["Next"]</button>
                    </div>
                </div>
            </div>
        }
    </section>
}

@code {
    private const int PageSize = 8;
    private List<TenantDto>? TenantList;
    private Guid? SelectedTenantId;
    private string SearchTerm { get; set; } = string.Empty;
    private string StatusFilter { get; set; } = "all";
    private int CurrentPage { get; set; } = 1;
    private string? LoadError;

    private IReadOnlyList<TenantDto> FilteredTenants =>
        (TenantList ?? [])
            .Where(MatchesSearch)
            .Where(MatchesFilter)
            .OrderBy(t => t.DisplayName)
            .ToList();

    private IReadOnlyList<TenantDto> VisibleTenants =>
        FilteredTenants
            .Skip((CurrentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();

    private TenantDto? SelectedTenant =>
        VisibleTenants.FirstOrDefault(t => t.Id == SelectedTenantId) ?? VisibleTenants.FirstOrDefault();

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredTenants.Count / (double)PageSize));
    private int ActiveTenants => TenantList?.Count(t => IsStatus(t.Status, "active")) ?? 0;
    private int ProvisioningTenants => TenantList?.Count(t => !IsStatus(t.Status, "active")) ?? 0;
    private TenantDto? LatestTenant => TenantList?.OrderByDescending(t => t.DisplayName).FirstOrDefault();
    private string NewestTenantLabel => LatestTenant?.DisplayName ?? L["None"];
    private string LatestTenantStatus => LatestTenant is null ? L["StatusNeutral"] : LocalizedStatus(LatestTenant.Status);
    private string LatestTenantDomain => LatestTenant?.PrimaryDomain ?? "-";

    private string PagingSummary
    {
        get
        {
            if (FilteredTenants.Count == 0)
            {
                return L["ShowingZeroResults"];
            }

            var start = ((CurrentPage - 1) * PageSize) + 1;
            var end = Math.Min(CurrentPage * PageSize, FilteredTenants.Count);
            return L["ShowingResults", start, end, FilteredTenants.Count];
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await RefreshTenantListAsync();
            EnsureSelection();
        }
        catch (Exception ex)
        {
            LoadError = L["TenantRegistryLoadError", ex.Message];
        }
    }

    private void NavigateToDetail(Guid id) =>
        NavigationManager.NavigateTo($"/tenants/{id}");

    private async Task OpenCreateTenantAsync()
    {
        var result = await DialogService.OpenAsync<TenantEditorPanel>(
            L["CreateTenantDialogTitle"],
            new Dictionary<string, object?>(),
            CreateDialogOptions());

        if (result is Guid createdTenantId && createdTenantId != Guid.Empty)
        {
            await RefreshTenantListAsync(createdTenantId);
        }
    }

    private async Task OpenEditTenantAsync(Guid tenantId)
    {
        var result = await DialogService.OpenSideAsync<TenantEditorPanel>(
            L["EditTenantDialogTitle"],
            new Dictionary<string, object?>
            {
                [nameof(TenantEditorPanel.TenantId)] = tenantId,
            },
            EditDialogOptions());

        if (result is Guid updatedTenantId && updatedTenantId != Guid.Empty)
        {
            await RefreshTenantListAsync(updatedTenantId);
        }
    }

    private bool MatchesSearch(TenantDto tenant)
    {
        if (string.IsNullOrWhiteSpace(SearchTerm))
        {
            return true;
        }

        return tenant.Code.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
               tenant.DisplayName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
               tenant.PrimaryDomain.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesFilter(TenantDto tenant) =>
        StatusFilter switch
        {
            "active" => IsStatus(tenant.Status, "active"),
            "other" => !IsStatus(tenant.Status, "active"),
            _ => true,
        };

    private void SetStatusFilter(string filter)
    {
        StatusFilter = filter;
        CurrentPage = 1;
        EnsureSelection();
    }

    private void ClearFilters()
    {
        SearchTerm = string.Empty;
        StatusFilter = "all";
        CurrentPage = 1;
        EnsureSelection();
    }

    private void OnSearchChanged(ChangeEventArgs args)
    {
        SearchTerm = args.Value?.ToString() ?? string.Empty;
        CurrentPage = 1;
        EnsureSelection();
    }

    private void SelectTenant(Guid tenantId) =>
        SelectedTenantId = tenantId;

    private void PreviousPage()
    {
        if (CurrentPage <= 1)
        {
            return;
        }

        CurrentPage--;
        EnsureSelection();
    }

    private void NextPage()
    {
        if (CurrentPage >= TotalPages)
        {
            return;
        }

        CurrentPage++;
        EnsureSelection();
    }

    private void EnsureSelection()
    {
        if (CurrentPage > TotalPages)
        {
            CurrentPage = TotalPages;
        }

        var selected = VisibleTenants.FirstOrDefault(t => t.Id == SelectedTenantId) ?? VisibleTenants.FirstOrDefault();
        SelectedTenantId = selected?.Id;
    }

    private async Task RefreshTenantListAsync(Guid? focusTenantId = null)
    {
        TenantList = (await TenantRegistryService.GetTenantsAsync()).ToList();
        if (focusTenantId.HasValue)
        {
            SelectedTenantId = focusTenantId;
        }
    }

    private string FilterButtonClass(string filter) =>
        StatusFilter == filter ? "filter-chip active" : "filter-chip";

    private static string RowClass(bool isSelected) =>
        isSelected ? "data-row selected" : "data-row";

    private static bool IsStatus(string? value, string expected) =>
        string.Equals(value, expected, StringComparison.OrdinalIgnoreCase);

    private string LocalizedStatus(string status) =>
        status.ToLowerInvariant() switch
        {
            "active" => L["StatusActive"],
            "completed" => L["StatusCompleted"],
            "failed" => L["StatusFailed"],
            "claimed" => L["StatusClaimed"],
            "running" => L["StatusRunning"],
            "provisioning" => L["StatusProvisioning"],
            _ => L["StatusNeutral"],
        };

    private static string StatusClass(string status)
    {
        if (string.Equals(status, "active", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "completed", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill success";
        }
        if (string.Equals(status, "failed", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill danger";
        }
        if (string.Equals(status, "claimed", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "running", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "provisioning", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill warning";
        }
        return "status-pill neutral";
    }

    private string TenantStatusCopy(TenantDto tenant)
    {
        if (IsStatus(tenant.Status, "active"))
        {
            return L["ActiveTenantsCopy"];
        }

        return L["ProvisioningTenantsCopy"];
    }

    private static DialogOptions CreateDialogOptions() => new()
    {
        CssClass = "platform-modal-dialog",
        WrapperCssClass = "platform-modal-wrapper",
        ContentCssClass = "platform-modal-content",
        Width = "min(820px, calc(100vw - 48px))",
        Height = "auto",
        Draggable = false,
        Resizable = false,
        CloseDialogOnEsc = true,
        CloseDialogOnOverlayClick = false,
    };

    private static SideDialogOptions EditDialogOptions() => new()
    {
        Position = DialogPosition.Right,
        ShowMask = true,
        CloseDialogOnOverlayClick = false,
        Width = "520px",
        CssClass = "platform-side-dialog",
        WrapperCssClass = "platform-side-dialog-wrapper",
        ContentCssClass = "platform-side-dialog-content",
    };
}
