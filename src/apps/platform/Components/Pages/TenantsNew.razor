@page "/tenants/new"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Platform:Write")]
@inject NavigationManager NavigationManager

<PageTitle>Create Tenant</PageTitle>

<section class="page-hero">
    <div>
        <p class="eyebrow">Provisioning</p>
        <h1>Create Tenant</h1>
        <p class="hero-copy">Legacy route retained for compatibility. The primary create workflow now lives inside the tenant registry as a side panel.</p>
    </div>
    <div class="hero-actions">
        <a href="/tenants" class="btn btn-secondary">Back to Registry</a>
    </div>
</section>

<TenantEditorPanel Embedded="true" OnCompleted="HandleCompletedAsync" />

@code {
    private Task HandleCompletedAsync(Guid tenantId)
    {
        NavigationManager.NavigateTo(tenantId == Guid.Empty ? "/tenants" : $"/tenants/{tenantId}");
        return Task.CompletedTask;
    }
}
