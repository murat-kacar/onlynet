@page "/settings"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Platform:Self")]
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<IdentityUser<Guid>> UserManager
@inject SignInManager<IdentityUser<Guid>> SignInManager
@inject IJSRuntime JSRuntime

<PageTitle>Settings</PageTitle>

<section class="page-hero">
    <div>
        <p class="eyebrow">Account</p>
        <h1>Settings</h1>
        <p class="hero-copy">Security, operator preferences, and the small control points that shape how the console feels day to day.</p>
    </div>
</section>

@if (LoadError is not null)
{
    <div class="alert alert-danger">@LoadError</div>
}
else
{
    <section class="stats-grid compact-stats">
        <article class="metric-card">
            <p class="metric-label">Account</p>
            <p class="metric-value metric-value-sm">@DisplayEmail</p>
            <p class="metric-footnote">Current platform identity</p>
        </article>
        <article class="metric-card">
            <p class="metric-label">UI Language</p>
            <p class="metric-value metric-value-sm">@PreferenceModel.Language</p>
            <p class="metric-footnote">Stored for this browser</p>
        </article>
        <article class="metric-card">
            <p class="metric-label">Time Zone</p>
            <p class="metric-value metric-value-sm">@PreferenceModel.TimeZone</p>
            <p class="metric-footnote">@PreferencePreview</p>
        </article>
    </section>

    <section class="panel">
        <div class="tab-strip" role="tablist" aria-label="Settings sections">
            <button type="button" class="@TabClass("security")" @onclick='() => SelectTab("security")'>Security</button>
            <button type="button" class="@TabClass("preferences")" @onclick='() => SelectTab("preferences")'>Preferences</button>
        </div>
    </section>

    @if (ActiveTab == "security")
    {
        <section class="detail-layout">
            <article class="panel detail-panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">Security</p>
                        <h3>Password Rotation</h3>
                    </div>
                    @if (MustRotatePassword)
                    {
                        <span class="status-pill warning">Required</span>
                    }
                </div>

                @if (SecuritySuccess is not null)
                {
                    <div class="alert alert-success">@SecuritySuccess</div>
                }

                @if (SecurityError is not null)
                {
                    <div class="alert alert-danger">@SecurityError</div>
                }

                <EditForm Model="@PasswordModel" OnValidSubmit="ChangePasswordAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="form-grid">
                        <div class="form-group form-span-2">
                            <label>Current Password</label>
                            <InputText @bind-Value="PasswordModel.CurrentPassword" type="password" class="form-control" />
                            <ValidationMessage For="() => PasswordModel.CurrentPassword" />
                        </div>

                        <div class="form-group">
                            <label>New Password</label>
                            <InputText @bind-Value="PasswordModel.NewPassword" type="password" class="form-control" />
                            <ValidationMessage For="() => PasswordModel.NewPassword" />
                        </div>

                        <div class="form-group">
                            <label>Confirm Password</label>
                            <InputText @bind-Value="PasswordModel.ConfirmPassword" type="password" class="form-control" />
                            <ValidationMessage For="() => PasswordModel.ConfirmPassword" />
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary" disabled="@IsSavingPassword">
                            @(IsSavingPassword ? "Updating..." : "Update Password")
                        </button>
                    </div>
                </EditForm>
            </article>

            <article class="panel detail-panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">Status</p>
                        <h3>Security Notes</h3>
                    </div>
                </div>

                <div class="detail-stack">
                    <section class="detail-section">
                        <p class="detail-title">Password Policy</p>
                        <p class="detail-copy">Rotate bootstrap credentials immediately, then keep this surface for voluntary changes and incident response.</p>
                    </section>

                    <section class="detail-section">
                        <p class="detail-title">Session Behavior</p>
                        <p class="detail-copy">A successful password change refreshes the current sign-in and clears any forced-rotation claim on the account.</p>
                    </section>
                </div>
            </article>
        </section>
    }
    else
    {
        <section class="detail-layout">
            <article class="panel detail-panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">Preferences</p>
                        <h3>Operator Defaults</h3>
                    </div>
                </div>

                @if (PreferenceSuccess is not null)
                {
                    <div class="alert alert-success">@PreferenceSuccess</div>
                }

                <EditForm Model="@PreferenceModel" OnValidSubmit="SavePreferencesAsync">
                    <div class="form-grid">
                        <div class="form-group">
                            <label>UI Language</label>
                            <InputSelect @bind-Value="PreferenceModel.Language" class="form-control">
                                <option value="en-GB">English (UK)</option>
                                <option value="tr-TR">Turkish</option>
                            </InputSelect>
                        </div>

                        <div class="form-group">
                            <label>Density</label>
                            <InputSelect @bind-Value="PreferenceModel.Density" class="form-control">
                                <option value="compact">Compact</option>
                                <option value="comfortable">Comfortable</option>
                            </InputSelect>
                        </div>

                        <div class="form-group form-span-2">
                            <label>Operator Time Zone</label>
                            <InputSelect @bind-Value="PreferenceModel.TimeZone" class="form-control">
                                <option value="UTC">UTC</option>
                                <option value="Europe/London">Europe/London</option>
                                <option value="Europe/Istanbul">Europe/Istanbul</option>
                                <option value="America/New_York">America/New_York</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary" disabled="@IsSavingPreferences">
                            @(IsSavingPreferences ? "Saving..." : "Save Preferences")
                        </button>
                    </div>
                </EditForm>
            </article>

            <article class="panel detail-panel">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">Preview</p>
                        <h3>Session Defaults</h3>
                    </div>
                </div>

                <div class="detail-stack">
                    <div class="kv-grid">
                        <div class="kv-item">
                            <span class="kv-label">Language</span>
                            <span class="kv-value">@PreferenceModel.Language</span>
                        </div>
                        <div class="kv-item">
                            <span class="kv-label">Density</span>
                            <span class="kv-value">@PreferenceModel.Density</span>
                        </div>
                        <div class="kv-item form-span-2">
                            <span class="kv-label">Time Zone Preview</span>
                            <span class="kv-value">@PreferencePreview</span>
                        </div>
                    </div>

                    <section class="detail-section">
                        <p class="detail-title">Scope</p>
                        <p class="detail-copy">These preferences are stored in the current browser and shape how the management console feels for this operator.</p>
                    </section>
                </div>
            </article>
        </section>
    }
}

@code {
    [SupplyParameterFromQuery(Name = "tab")]
    public string? Tab { get; set; }

    private bool _preferencesLoaded;
    private bool IsSavingPassword;
    private bool IsSavingPreferences;
    private bool MustRotatePassword;
    private string ActiveTab { get; set; } = "security";
    private string? DisplayEmail;
    private string? LoadError;
    private string? PreferenceSuccess;
    private string? SecurityError;
    private string? SecuritySuccess;
    private PasswordChangeInput PasswordModel { get; set; } = new();
    private UserPreferenceInput PreferenceModel { get; set; } = new();

    private string PreferencePreview =>
        $"{PreferenceModel.TimeZone} · {FormatPreviewTime()}";

    protected override async Task OnInitializedAsync()
    {
        ActiveTab = string.Equals(Tab, "preferences", StringComparison.OrdinalIgnoreCase) ? "preferences" : "security";

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var principal = authState.User;
            MustRotatePassword = principal.HasClaim(claim => string.Equals(claim.Type, PasswordChangeRequiredMiddleware.MustChangePasswordClaim, StringComparison.Ordinal));

            var user = await UserManager.GetUserAsync(principal);
            DisplayEmail = user?.Email ?? principal.Identity?.Name ?? "Operator";
        }
        catch (Exception ex)
        {
            LoadError = $"Settings failed to load: {ex.Message}";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _preferencesLoaded)
        {
            return;
        }

        var stored = await JSRuntime.InvokeAsync<UserPreferenceInput?>("tabflowSettings.load");
        if (stored is not null)
        {
            PreferenceModel = stored;
            await JSRuntime.InvokeVoidAsync("tabflowSettings.apply", PreferenceModel);
            await InvokeAsync(StateHasChanged);
        }

        _preferencesLoaded = true;
    }

    private void SelectTab(string tab)
    {
        ActiveTab = tab;
        PreferenceSuccess = null;
        SecuritySuccess = null;
        SecurityError = null;
    }

    private async Task ChangePasswordAsync()
    {
        IsSavingPassword = true;
        SecurityError = null;
        SecuritySuccess = null;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);
            if (user is null)
            {
                SecurityError = "The current account could not be loaded.";
                return;
            }

            if (!string.Equals(PasswordModel.NewPassword, PasswordModel.ConfirmPassword, StringComparison.Ordinal))
            {
                SecurityError = "The new password and confirmation do not match.";
                return;
            }

            var result = await UserManager.ChangePasswordAsync(user, PasswordModel.CurrentPassword, PasswordModel.NewPassword);
            if (!result.Succeeded)
            {
                SecurityError = string.Join(" ", result.Errors.Select(error => error.Description));
                return;
            }

            var existingClaims = await UserManager.GetClaimsAsync(user);
            foreach (var claim in existingClaims)
            {
                if (string.Equals(claim.Type, PasswordChangeRequiredMiddleware.MustChangePasswordClaim, StringComparison.Ordinal))
                {
                    await UserManager.RemoveClaimAsync(user, claim);
                }
            }

            await SignInManager.RefreshSignInAsync(user);
            MustRotatePassword = false;
            PasswordModel = new PasswordChangeInput();
            SecuritySuccess = "Password updated. Your session has been refreshed.";
        }
        catch (Exception ex)
        {
            SecurityError = $"Password change failed: {ex.Message}";
        }
        finally
        {
            IsSavingPassword = false;
        }
    }

    private async Task SavePreferencesAsync()
    {
        IsSavingPreferences = true;
        PreferenceSuccess = null;

        try
        {
            await JSRuntime.InvokeVoidAsync("tabflowSettings.save", PreferenceModel);
            await JSRuntime.InvokeVoidAsync("tabflowSettings.apply", PreferenceModel);
            PreferenceSuccess = "Preferences saved for this browser.";
        }
        finally
        {
            IsSavingPreferences = false;
        }
    }

    private string TabClass(string tab) =>
        ActiveTab == tab ? "tab-chip active" : "tab-chip";

    private string FormatPreviewTime()
    {
        return PreferenceModel.TimeZone switch
        {
            "Europe/London" => DateTimeOffset.UtcNow.ToOffset(TimeSpan.Zero).ToString("HH:mm 'UTC'"),
            "Europe/Istanbul" => DateTimeOffset.UtcNow.ToOffset(TimeSpan.FromHours(3)).ToString("HH:mm 'UTC+3'"),
            "America/New_York" => DateTimeOffset.UtcNow.ToOffset(TimeSpan.FromHours(-4)).ToString("HH:mm 'UTC-4'"),
            _ => DateTimeOffset.UtcNow.ToString("HH:mm 'UTC'"),
        };
    }

    private sealed class PasswordChangeInput
    {
        [Required]
        public string CurrentPassword { get; set; } = string.Empty;

        [Required]
        [MinLength(8)]
        public string NewPassword { get; set; } = string.Empty;

        [Required]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    private sealed class UserPreferenceInput
    {
        public string Language { get; set; } = "en-GB";
        public string TimeZone { get; set; } = "Europe/London";
        public string Density { get; set; } = "compact";
    }
}
