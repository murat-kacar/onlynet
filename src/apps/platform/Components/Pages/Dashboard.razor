@page "/"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "Platform:Read")]
@inject IStringLocalizer<PlatformText> L
@inject NavigationManager NavigationManager
@inject ITenantRegistryService TenantRegistryService
@inject IProvisioningJobReadService ProvisioningJobReadService

<PageTitle>@L["DashboardTitle"]</PageTitle>

<SectionContent SectionName="platform-header">
    <div>
        <p class="eyebrow">@L["OverviewEyebrow"]</p>
        <h2>@L["DashboardTitle"]</h2>
        <p class="hero-copy">@L["DashboardHero"]</p>
    </div>
</SectionContent>

<SectionContent SectionName="platform-inspector">
    <div class="console-context">
        <section class="context-card">
            <p class="eyebrow">@L["MetricTenants"]</p>
            <p class="context-stat">@ActiveTenantCount</p>
            <p class="detail-copy">@L["DashboardActiveProvisioning", ActiveTenantCount, ProvisioningTenantCount]</p>
        </section>

        <section class="context-card">
            <p class="eyebrow">@L["AttentionEyebrow"]</p>
            <h4>@L["WhatNeedsEyes"]</h4>
            <p class="detail-copy">@L["FailedJobsCopy"]</p>
            <p class="context-stat">@FailedJobCount</p>
        </section>

        <section class="context-card">
            <p class="eyebrow">@L["MetricNewestTenant"]</p>
            <h4>@NewestTenantLabel</h4>
            <p class="detail-copy">@L["MetricNewestTenantCopy"]</p>
        </section>
    </div>
</SectionContent>

@if (LoadError is not null)
{
    <div class="alert alert-danger">@LoadError</div>
}
else if (Tenants is null || Jobs is null)
{
    <section class="empty-state">
        <h3>@L["LoadingPlatformData"]</h3>
        <p>@L["LoadingPlatformDataCopy"]</p>
    </section>
}
else
{
    <section class="stats-grid">
        <article class="metric-card">
            <p class="metric-label">@L["MetricTenants"]</p>
            <p class="metric-value">@Tenants.Count</p>
            <p class="metric-footnote">@L["DashboardActiveProvisioning", ActiveTenantCount, ProvisioningTenantCount]</p>
        </article>
        <article class="metric-card">
            <p class="metric-label">@L["MetricOpenJobs"]</p>
            <p class="metric-value">@OpenJobCount</p>
            <p class="metric-footnote">@L["DashboardFailedClaimed", FailedJobCount, ClaimedJobCount]</p>
        </article>
        <article class="metric-card">
            <p class="metric-label">@L["MetricRegions"]</p>
            <p class="metric-value">@DistinctTimeZones</p>
            <p class="metric-footnote">@L["DashboardCurrenciesLanguages", DistinctCurrencies, DistinctLanguages]</p>
        </article>
        <article class="metric-card accent-card">
            <p class="metric-label">@L["MetricNewestTenant"]</p>
            <p class="metric-value metric-value-sm">@NewestTenantLabel</p>
            <p class="metric-footnote">@L["MetricNewestTenantCopy"]</p>
        </article>
    </section>

    <section class="dashboard-grid platform-dashboard-grid">
        <article class="panel">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">@L["ProvisioningEyebrow"]</p>
                    <h3>@L["QueueSnapshot"]</h3>
                </div>
                <a href="/jobs" class="text-link">@L["AllJobs"]</a>
            </div>

            @if (RecentJobs.Count == 0)
            {
                <div class="empty-state compact-empty">
                    <h4>@L["NoProvisioningJobsYet"]</h4>
                    <p>@L["NoProvisioningJobsYetCopy"]</p>
                </div>
            }
            else
            {
                <div class="stack-list">
                    @foreach (var job in RecentJobs)
                    {
                        <button type="button" class="list-row-button" @onclick='() => NavigationManager.NavigateTo("/jobs")'>
                            <div>
                                <p class="list-title">@job.Type</p>
                                <p class="list-subtitle">@L["RecentJobForTenant", ShortId(job.Id), ResolveTenant(job.TenantId)]</p>
                            </div>
                            <div class="list-meta">
                                <span class="@StatusClass(job.Status)">@LocalizedStatus(job.Status)</span>
                                <span>@RelativeTime(job.UpdatedAt)</span>
                            </div>
                        </button>
                    }
                </div>
            }
        </article>

        <article class="panel">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">@L["RegistryEyebrow"]</p>
                    <h3>@L["RecentTenants"]</h3>
                </div>
                <a href="/tenants" class="text-link">@L["Registry"]</a>
            </div>

            @if (RecentTenants.Count == 0)
            {
                <div class="empty-state compact-empty">
                    <h4>@L["NoTenantsYet"]</h4>
                    <p>@L["NoTenantsYetCopy"]</p>
                </div>
            }
            else
            {
                <div class="stack-list">
                    @foreach (var tenant in RecentTenants)
                    {
                        <button type="button" class="list-row-button" @onclick='() => NavigationManager.NavigateTo($"/tenants/{tenant.Id}")'>
                            <div>
                                <p class="list-title">@tenant.DisplayName</p>
                                <p class="list-subtitle">@tenant.PrimaryDomain</p>
                            </div>
                            <div class="list-meta">
                                <span class="@StatusClass(tenant.Status)">@LocalizedStatus(tenant.Status)</span>
                                <span>@tenant.CurrencyCode · @tenant.LanguageCode</span>
                            </div>
                        </button>
                    }
                </div>
            }
        </article>

        <article class="panel">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">@L["AttentionEyebrow"]</p>
                    <h3>@L["WhatNeedsEyes"]</h3>
                </div>
            </div>

            <div class="attention-grid">
                <div class="attention-card">
                    <p class="attention-label">@L["FailedJobs"]</p>
                    <p class="attention-value">@FailedJobCount</p>
                    <p class="attention-copy">@L["FailedJobsCopy"]</p>
                </div>
                <div class="attention-card">
                    <p class="attention-label">@L["PendingTenants"]</p>
                    <p class="attention-value">@ProvisioningTenantCount</p>
                    <p class="attention-copy">@L["PendingTenantsCopy"]</p>
                </div>
            </div>
        </article>
    </section>
}

@code {
    private List<TenantDto>? Tenants;
    private List<JobDto>? Jobs;
    private string? LoadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Tenants = (await TenantRegistryService.GetTenantsAsync()).ToList();
            Jobs = (await ProvisioningJobReadService.GetJobsAsync()).ToList();
        }
        catch (Exception ex)
        {
            LoadError = L["DashboardLoadError", ex.Message];
        }
    }

    private int ActiveTenantCount => Tenants?.Count(t => IsStatus(t.Status, "active")) ?? 0;
    private int ProvisioningTenantCount => Tenants?.Count(t => !IsStatus(t.Status, "active")) ?? 0;
    private int OpenJobCount => Jobs?.Count(j => !IsStatus(j.Status, "completed")) ?? 0;
    private int FailedJobCount => Jobs?.Count(j => IsStatus(j.Status, "failed")) ?? 0;
    private int ClaimedJobCount => Jobs?.Count(j => !string.IsNullOrWhiteSpace(j.ClaimedBy)) ?? 0;
    private int DistinctTimeZones => Tenants?.Select(t => t.TimeZone).Distinct(StringComparer.OrdinalIgnoreCase).Count() ?? 0;
    private int DistinctCurrencies => Tenants?.Select(t => t.CurrencyCode).Distinct(StringComparer.OrdinalIgnoreCase).Count() ?? 0;
    private int DistinctLanguages => Tenants?.Select(t => t.LanguageCode).Distinct(StringComparer.OrdinalIgnoreCase).Count() ?? 0;
    private string NewestTenantLabel => RecentTenants.FirstOrDefault()?.DisplayName ?? L["None"];
    private IReadOnlyList<TenantDto> RecentTenants => (Tenants ?? []).Take(5).ToList();
    private IReadOnlyList<JobDto> RecentJobs => (Jobs ?? []).Take(5).ToList();

    private static bool IsStatus(string? value, string expected) =>
        string.Equals(value, expected, StringComparison.OrdinalIgnoreCase);

    private string ResolveTenant(Guid tenantId) =>
        Tenants?.FirstOrDefault(t => t.Id == tenantId)?.DisplayName ?? ShortId(tenantId);

    private static string ShortId(Guid id) => id.ToString("N")[..8];

    private string RelativeTime(DateTimeOffset value)
    {
        var delta = DateTimeOffset.UtcNow - value.ToUniversalTime();
        if (delta.TotalMinutes < 1)
        {
            return L["JustNow"];
        }
        if (delta.TotalHours < 1)
        {
            return L["MinutesAgo", Math.Max(1, (int)delta.TotalMinutes)];
        }
        if (delta.TotalDays < 1)
        {
            return L["HoursAgo", Math.Max(1, (int)delta.TotalHours)];
        }
        return L["DaysAgo", Math.Max(1, (int)delta.TotalDays)];
    }

    private string LocalizedStatus(string status) =>
        status.ToLowerInvariant() switch
        {
            "active" => L["StatusActive"],
            "completed" => L["StatusCompleted"],
            "failed" => L["StatusFailed"],
            "claimed" => L["StatusClaimed"],
            "running" => L["StatusRunning"],
            "provisioning" => L["StatusProvisioning"],
            _ => L["StatusNeutral"],
        };

    private static string StatusClass(string status)
    {
        if (string.Equals(status, "active", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "completed", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill success";
        }
        if (string.Equals(status, "failed", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill danger";
        }
        if (string.Equals(status, "claimed", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "running", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill warning";
        }
        return "status-pill neutral";
    }
}
