@attribute [Authorize(Policy = "Platform:Write")]
@inject IStringLocalizer<PlatformText> L
@inject ITenantRegistryService TenantRegistryService
@inject DialogService DialogService

@if (LoadError is not null)
{
    <div class="alert alert-danger">@LoadError</div>
}
else
{
    @if (SubmitError is not null)
    {
        <div class="alert alert-danger">@SubmitError</div>
    }

    @if (SubmitSuccess is not null)
    {
        <div class="alert alert-success">@SubmitSuccess</div>
    }

    <section class="dialog-stack">
        <article class="panel create-panel">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">@L["Input"]</p>
                    <h3>@(IsEditMode ? L["RegionalSettings"] : L["TenantRegistration"])</h3>
                </div>
                @if (IsEditMode)
                {
                    <span class="@StatusClass(CurrentStatus)">@LocalizedStatus(CurrentStatus)</span>
                }
            </div>

            <EditForm Model="@Model" OnValidSubmit="HandleSubmitAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-grid">
                    @if (IsEditMode)
                    {
                        <div class="kv-item">
                            <span class="kv-label">@L["TableTenant"]</span>
                            <span class="kv-value">@Fallback(Model.DisplayName)</span>
                        </div>

                        <div class="kv-item">
                            <span class="kv-label">@L["TenantCode"]</span>
                            <span class="kv-value">@Fallback(Model.Code)</span>
                        </div>
                    }
                    else
                    {
                        <div class="form-group">
                            <label>@L["TenantCode"]</label>
                            <InputText @bind-Value="Model.Code" class="form-control" />
                            <ValidationMessage For="() => Model.Code" />
                        </div>

                        <div class="form-group">
                            <label>@L["DisplayName"]</label>
                            <InputText @bind-Value="Model.DisplayName" class="form-control" />
                            <ValidationMessage For="() => Model.DisplayName" />
                        </div>

                        <div class="form-group form-span-2">
                            <label>@L["PrimaryDomain"]</label>
                            <InputText @bind-Value="Model.PrimaryDomain" class="form-control" />
                            <ValidationMessage For="() => Model.PrimaryDomain" />
                        </div>

                        <div class="form-group form-span-2">
                            <label>@L["OwnerEmail"]</label>
                            <InputText @bind-Value="Model.IntendedOwnerEmail" class="form-control" />
                            <ValidationMessage For="() => Model.IntendedOwnerEmail" />
                        </div>
                    }

                    <div class="form-group">
                        <label>@L["Language"]</label>
                        <InputText @bind-Value="Model.LanguageCode" class="form-control" />
                        <ValidationMessage For="() => Model.LanguageCode" />
                    </div>

                    <div class="form-group">
                        <label>@L["Currency"]</label>
                        <InputText @bind-Value="Model.CurrencyCode" class="form-control" />
                        <ValidationMessage For="() => Model.CurrencyCode" />
                    </div>

                    <div class="form-group form-span-2">
                        <label>@L["TimeZone"]</label>
                        <InputText @bind-Value="Model.TimeZone" class="form-control" />
                        <ValidationMessage For="() => Model.TimeZone" />
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary" disabled="@IsSubmitting">
                        @(IsSubmitting ? BusyLabel : SubmitLabel)
                    </button>
                    @if (Embedded)
                    {
                        <button type="button" class="btn btn-secondary" @onclick="CancelEmbedded">@L["Cancel"]</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-secondary" @onclick="CloseDialogAsync">@L["Cancel"]</button>
                    }
                </div>
            </EditForm>
        </article>

        <article class="panel create-panel">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">@L["Preview"]</p>
                    <h3>@(IsEditMode ? L["PreviewUpdate"] : L["PreviewRegistration"])</h3>
                </div>
            </div>

            <div class="kv-grid">
                <div class="kv-item">
                    <span class="kv-label">@L["TableTenant"]</span>
                    <span class="kv-value">@Fallback(Model.DisplayName)</span>
                </div>
                <div class="kv-item">
                    <span class="kv-label">@L["TenantCode"]</span>
                    <span class="kv-value">@Fallback(Model.Code)</span>
                </div>
                <div class="kv-item">
                    <span class="kv-label">@L["TableDomain"]</span>
                    <span class="kv-value">@Fallback(Model.PrimaryDomain)</span>
                </div>
                <div class="kv-item">
                    <span class="kv-label">@L["Locale"]</span>
                    <span class="kv-value">@Fallback($"{Model.LanguageCode} · {Model.CurrencyCode}")</span>
                </div>
                <div class="kv-item">
                    <span class="kv-label">@L["TimeZone"]</span>
                    <span class="kv-value">@Fallback(Model.TimeZone)</span>
                </div>
                <div class="kv-item">
                    <span class="kv-label">@L["Owner"]</span>
                    <span class="kv-value">@Fallback(Model.IntendedOwnerEmail)</span>
                </div>
            </div>
        </article>
    </section>
}

@code {
    private bool _createInitialized;
    private Guid? _loadedTenantId;
    private CreateTenantModel Model = new();
    private bool IsSubmitting;
    private string? CurrentStatus;
    private string? LoadError;
    private string? SubmitError;
    private string? SubmitSuccess;

    [Parameter]
    public bool Embedded { get; set; }

    [Parameter]
    public Guid? TenantId { get; set; }

    [Parameter]
    public EventCallback<Guid> OnCompleted { get; set; }

    private bool IsEditMode => TenantId.HasValue;
    private string SubmitLabel => IsEditMode ? L["SaveChanges"] : L["CreateTenant"];
    private string BusyLabel => IsEditMode ? L["SavingChanges"] : L["Creating"];

    protected override async Task OnParametersSetAsync()
    {
        if (!IsEditMode && _createInitialized)
        {
            return;
        }

        if (IsEditMode && TenantId == _loadedTenantId && !string.IsNullOrWhiteSpace(Model.Code))
        {
            return;
        }

        await LoadModelAsync();
    }

    private async Task LoadModelAsync()
    {
        LoadError = null;
        SubmitError = null;
        SubmitSuccess = null;

        if (!IsEditMode)
        {
            _createInitialized = true;
            _loadedTenantId = null;
            CurrentStatus = null;
            Model = new CreateTenantModel
            {
                LanguageCode = "en-GB",
                CurrencyCode = "GBP",
                TimeZone = "Europe/London",
            };
            return;
        }

        try
        {
            _createInitialized = false;
            var tenant = await TenantRegistryService.GetTenantAsync(TenantId!.Value);
            if (tenant is null)
            {
                LoadError = L["TenantEditLoadMissing"];
                return;
            }

            _loadedTenantId = tenant.Id;
            CurrentStatus = tenant.Status;
            Model = new CreateTenantModel
            {
                Code = tenant.Code,
                DisplayName = tenant.DisplayName,
                PrimaryDomain = tenant.PrimaryDomain,
                LanguageCode = tenant.LanguageCode,
                CurrencyCode = tenant.CurrencyCode,
                TimeZone = tenant.TimeZone,
                IntendedOwnerEmail = tenant.IntendedOwnerEmail,
            };
        }
        catch (Exception ex)
        {
            LoadError = L["EditorLoadError", ex.Message];
        }
    }

    private async Task HandleSubmitAsync()
    {
        IsSubmitting = true;
        SubmitError = null;
        SubmitSuccess = null;

        try
        {
            if (IsEditMode)
            {
                var ok = await TenantRegistryService.UpdateTenantRegionalSettingsAsync(TenantId!.Value, new UpdateTenantRequest(
                    Model.LanguageCode.Trim(),
                    Model.CurrencyCode.Trim(),
                    Model.TimeZone.Trim()));

                if (!ok)
                {
                    SubmitError = L["TenantUpdateMissing"];
                    return;
                }

                SubmitSuccess = L["TenantUpdatedSuccess"];
                await CompleteAsync(TenantId.Value);
                return;
            }

            var created = await TenantRegistryService.CreateTenantAsync(new CreateTenantRequest(
                Model.Code.Trim(),
                Model.DisplayName.Trim(),
                Model.PrimaryDomain.Trim(),
                Model.LanguageCode.Trim(),
                Model.CurrencyCode.Trim(),
                Model.TimeZone.Trim(),
                Model.IntendedOwnerEmail.Trim()));

            SubmitSuccess = L["TenantCreatedSuccess", created.DisplayName];
            await CompleteAsync(created.Id);
        }
        catch (Exception ex)
        {
            SubmitError = IsEditMode
                ? L["TenantUpdateFailed", ex.Message]
                : L["TenantCreateFailed", ex.Message];
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task CompleteAsync(Guid tenantId)
    {
        if (OnCompleted.HasDelegate)
        {
            await OnCompleted.InvokeAsync(tenantId);
        }

        if (!Embedded)
        {
            await DialogService.CloseSideAsync(tenantId);
        }
    }

    private Task CloseDialogAsync() => DialogService.CloseSideAsync(null);

    private async Task CancelEmbedded()
    {
        if (OnCompleted.HasDelegate)
        {
            await OnCompleted.InvokeAsync(Guid.Empty);
        }
    }

    private string Fallback(string? value) =>
        string.IsNullOrWhiteSpace(value) ? L["Pending"] : value;

    private string LocalizedStatus(string? status) =>
        status?.ToLowerInvariant() switch
        {
            "active" => L["StatusActive"],
            "completed" => L["StatusCompleted"],
            "failed" => L["StatusFailed"],
            "claimed" => L["StatusClaimed"],
            "running" => L["StatusRunning"],
            "provisioning" => L["StatusProvisioning"],
            _ => L["StatusNeutral"],
        };

    private static string StatusClass(string? status)
    {
        if (string.Equals(status, "active", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "completed", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill success";
        }

        if (string.Equals(status, "failed", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill danger";
        }

        if (string.Equals(status, "claimed", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "running", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(status, "provisioning", StringComparison.OrdinalIgnoreCase))
        {
            return "status-pill warning";
        }

        return "status-pill neutral";
    }

    private sealed class CreateTenantModel
    {
        [Required]
        public string Code { get; set; } = string.Empty;

        [Required]
        public string DisplayName { get; set; } = string.Empty;

        [Required]
        public string PrimaryDomain { get; set; } = string.Empty;

        [Required]
        public string LanguageCode { get; set; } = string.Empty;

        [Required]
        public string CurrencyCode { get; set; } = string.Empty;

        [Required]
        public string TimeZone { get; set; } = string.Empty;

        [Required]
        [EmailAddress]
        public string IntendedOwnerEmail { get; set; } = string.Empty;
    }
}
