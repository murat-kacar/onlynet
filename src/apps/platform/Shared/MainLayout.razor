@inherits LayoutComponentBase
@namespace TabFlow.Platform.Shared
@inject IStringLocalizer<PlatformText> L

<div class="platform-shell">
    <aside class="shell-sidebar">
        <div class="brand-block">
            <p class="eyebrow">@L["BrandEyebrow"]</p>
            <h1>TabFlow</h1>
            <p class="brand-copy">@L["BrandCopy"]</p>
        </div>

        <nav class="shell-nav" aria-label="Platform">
            <NavLink href="/" Match="NavLinkMatch.All" class="nav-link">
                @L["NavOverview"]
            </NavLink>
            <NavLink href="/tenants" class="nav-link">
                @L["NavTenants"]
            </NavLink>
            <NavLink href="/jobs" class="nav-link">
                @L["NavJobs"]
            </NavLink>
            <NavLink href="/audit" class="nav-link">
                @L["NavAudit"]
            </NavLink>
            <NavLink href="/settings" class="nav-link">
                @L["NavSettings"]
            </NavLink>
        </nav>

        <div class="sidebar-footnote">
            <p>@L["SidebarFootnote"]</p>
        </div>
    </aside>

    <div class="shell-main">
        <header class="shell-header">
            <div>
                <p class="eyebrow">@L["ShellEyebrow"]</p>
                <h2>@L["ShellTitle"]</h2>
            </div>
        </header>

        <main class="shell-content">
            @Body
        </main>
    </div>
</div>
