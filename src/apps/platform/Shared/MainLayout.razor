@inherits LayoutComponentBase
@namespace TabFlow.Platform.Shared
@inject IStringLocalizer<PlatformText> L
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject PlatformUserPreferenceService PreferenceService

<div class="platform-shell @(SidebarCollapsed ? "sidebar-collapsed" : null) @(InspectorCollapsed ? "inspector-collapsed" : null)" data-ui-density="@ShellDensity">
    <aside class="shell-sidebar">
        <div class="sidebar-header">
            <div class="brand-block">
                <p class="eyebrow">@L["BrandEyebrow"]</p>
                <div class="brand-lockup">
                    <span class="brand-mark" aria-hidden="true">
                        <span></span>
                        <span></span>
                    </span>
                    <h1>IoTable</h1>
                </div>
                <p class="brand-copy">@L["BrandCopy"]</p>
            </div>
        </div>

        <div class="sidebar-section">
            <p class="sidebar-section-label">@L["ShellTitle"]</p>
            <nav class="shell-nav" aria-label="Platform">
                <NavLink href="/" Match="NavLinkMatch.All" class="nav-link">
                    @L["NavOverview"]
                </NavLink>
                <NavLink href="/tenants" class="nav-link">
                    @L["NavTenants"]
                </NavLink>
                <NavLink href="/jobs" class="nav-link">
                    @L["NavJobs"]
                </NavLink>
                <NavLink href="/audit" class="nav-link">
                    @L["NavAudit"]
                </NavLink>
                <NavLink href="/settings" class="nav-link">
                    @L["NavSettings"]
                </NavLink>
            </nav>
        </div>

        <div class="sidebar-footnote">
            <p>@L["SidebarFootnote"]</p>
        </div>
    </aside>

    <div class="shell-stage">
        <header class="shell-topbar">
            <div class="topbar-start">
                <button type="button" class="chrome-toggle" @onclick="ToggleSidebar" aria-label="@L[SidebarCollapsed ? "ExpandNavigation" : "CollapseNavigation"]">
                    <span aria-hidden="true">@(!SidebarCollapsed ? "<<" : ">>")</span>
                </button>
                <div class="shell-slot shell-slot-title">
                    <SectionOutlet SectionName="platform-header" />
                </div>
                <div class="shell-slot-fallback">
                    <p class="eyebrow">@L["ShellEyebrow"]</p>
                    <h2>@L["ShellTitle"]</h2>
                </div>
            </div>

            <div class="topbar-end">
                <div class="shell-slot shell-slot-actions">
                    <SectionOutlet SectionName="platform-header-actions" />
                </div>
                <button type="button" class="chrome-toggle" @onclick="ToggleInspector" aria-label="@L[InspectorCollapsed ? "ShowContextPanel" : "HideContextPanel"]">
                    <span aria-hidden="true">[]</span>
                </button>
            </div>
        </header>

        <div class="shell-body">
            <main class="shell-content">
                @Body
            </main>

            <aside class="shell-inspector">
                <div class="shell-inspector-header">
                    <p class="eyebrow">@L["ContextPanel"]</p>
                </div>
                <div class="shell-inspector-content">
                    <SectionOutlet SectionName="platform-inspector" />
                </div>
            </aside>
        </div>
    </div>
</div>

@code {
    private string ShellDensity { get; set; } = PlatformUserPreferenceService.DefaultDensity;
    private bool SidebarCollapsed { get; set; }
    private bool InspectorCollapsed { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true)
            {
                var preference = await PreferenceService.GetForPrincipalAsync(authState.User);
                ShellDensity = preference.Density;
            }
        }
        catch
        {
            ShellDensity = PlatformUserPreferenceService.DefaultDensity;
        }
    }

    private void ToggleSidebar() => SidebarCollapsed = !SidebarCollapsed;
    private void ToggleInspector() => InspectorCollapsed = !InspectorCollapsed;
}
