@page "/login"
@model LoginModel
@{ ViewData["Title"] = "Login"; }

<section class="auth-brand-panel">
    <p class="eyebrow">IoTable Platform</p>
    <div class="brand-lockup">
        <span class="brand-mark" aria-hidden="true">
            <span></span>
            <span></span>
        </span>
        <h1>IoTable</h1>
    </div>
    <p class="auth-copy">Management Console access for tenant lifecycle, provisioning flow, and operational control.</p>
</section>

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <p>External sign-in could not be completed. Check the identity provider configuration and try again.</p>
}

@if (Model.ExternalIdentityEnabled)
{
    <form method="post">
        <input type="hidden" asp-for="ReturnUrl" />
        <button type="submit">Sign in with Keycloak</button>
    </form>
}
else
{
    <form method="post">
        <input type="hidden" asp-for="ReturnUrl" />
        <div>
            <label>Email</label>
            <input type="email" name="email" required />
        </div>
        <div>
            <label>Password</label>
            <input type="password" name="password" required />
        </div>
        <button type="submit">Login</button>
    </form>
}
